  },
  {
    "index": 48,
    "start": "0:02:36.55",
    "end": "0:02:37.17",
    "text": "Научный консультант:     smallgrin"
  },
  {
    "index": 49,
    "start": "0:02:44.31",
    "end": "0:02:47.52",
