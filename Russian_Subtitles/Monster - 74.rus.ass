Dialogue: 0,0:00:02.00,0:00:04.37,Default,,0000,0000,0000,,{\i1}"И повелел Зевс,
Dialogue: 0,0:00:04.37,0:00:06.58,Default,,0000,0000,0000,,{\i1}дабы люди, живущие на земле,
Dialogue: 0,0:00:06.58,0:00:09.59,Default,,0000,0000,0000,,{\i1}обрели знание, как сеять семена и снимать урожаи с полей".
Dialogue: 0,0:00:09.59,0:00:10.50,Default,,0000,0000,0000,,Карл.
Dialogue: 0,0:00:10.92,0:00:12.76,Default,,0000,0000,0000,,Ты снова ошибся в произношении.
Dialogue: 0,0:00:13.30,0:00:14.68,Default,,0000,0000,0000,,Прости.
Dialogue: 0,0:00:14.68,0:00:16.26,Default,,0000,0000,0000,,Я стараюсь следить, но...
Dialogue: 0,0:00:16.89,0:00:18.89,Default,,0000,0000,0000,,Признаю, ты стал лучше читать.
Dialogue: 0,0:00:19.22,0:00:21.52,Default,,0000,0000,0000,,Когда ты впервые пришёл ко мне,
Dialogue: 0,0:00:21.52,0:00:25.48,Default,,0000,0000,0000,,я подумал, что такой неуч делает у меня.
Dialogue: 0,0:00:26.60,0:00:27.35,Default,,0000,0000,0000,,Да...
Dialogue: 0,0:00:28.31,0:00:29.69,Default,,0000,0000,0000,,Что случилось с ним?
Dialogue: 0,0:00:31.03,0:00:33.44,Default,,0000,0000,0000,,С тем врачом-японцем.
Dialogue: 0,0:00:34.95,0:00:37.87,Default,,0000,0000,0000,,Я слышал, он путешествует по миру.
Dialogue: 0,0:00:38.49,0:00:40.08,Default,,0000,0000,0000,,Вот как.
Dialogue: 0,0:00:42.04,0:00:46.50,Default,,0000,0000,0000,,Надеюсь, мы ещё встретимся с ним.
Dialogue: 0,0:00:46.96,0:00:47.79,Default,,0000,0000,0000,,Да.
Dialogue: 0,0:02:26.39,0:02:30.89,Name,,0000,0000,0000,,{\fad(700,620)\pos(315,209)\fscy112}Последняя глава
Dialogue: 0,0:02:26.39,0:02:30.89,Name,,0000,0000,0000,,{\fad(700,620)\pos(328,400)\fscx120}Настоящий Монстр
Dialogue: 0,0:02:30.64,0:02:32.56,Default,,0000,0000,0000,,Нашла работу?
Dialogue: 0,0:02:32.56,0:02:34.10,Default,,0000,0000,0000,,Это здорово!
Dialogue: 0,0:02:34.10,0:02:35.73,Default,,0000,0000,0000,,И кем ты работаешь?
Dialogue: 0,0:02:36.10,0:02:38.23,Default,,0000,0000,0000,,Оформителем интерьеров.
Dialogue: 0,0:02:38.48,0:02:39.94,Default,,0000,0000,0000,,Понимаю.
Dialogue: 0,0:02:39.94,0:02:44.07,Default,,0000,0000,0000,,У тебя намётанный взгляд на красивые мелочи.
Dialogue: 0,0:02:44.82,0:02:48.78,Default,,0000,0000,0000,,Моя работа немного отличается от обычной.
Dialogue: 0,0:02:49.91,0:02:51.83,Default,,0000,0000,0000,,Я занимаюсь кухнями.
Dialogue: 0,0:02:53.83,0:02:55.33,Default,,0000,0000,0000,,Разве не забавно?
Dialogue: 0,0:02:55.33,0:02:58.58,Default,,0000,0000,0000,,Раньше я никогда ничего на кухне не делала.
Dialogue: 0,0:02:59.34,0:03:02.84,Default,,0000,0000,0000,,Может, заказать тебе мою кухню.
Dialogue: 0,0:03:03.13,0:03:03.96,Default,,0000,0000,0000,,Легко.
Dialogue: 0,0:03:04.47,0:03:09.09,Default,,0000,0000,0000,,Что-то говорит мне, что тебе нравятся богато обставленные кухни.
Dialogue: 0,0:03:09.30,0:03:10.60,Default,,0000,0000,0000,,Немного.
Dialogue: 0,0:03:14.56,0:03:16.48,Default,,0000,0000,0000,,Ты не пьёшь?
Dialogue: 0,0:03:16.77,0:03:17.72,Default,,0000,0000,0000,,Да, {\alpha&HFF&}ни капли.
Dialogue: 0,0:03:17.72,0:03:18.77,Default,,0000,0000,0000,,Да, ни капли.
Dialogue: 0,0:03:18.77,0:03:19.81,Default,,0000,0000,0000,,Это замечательно.
Dialogue: 0,0:03:20.27,0:03:22.86,Default,,0000,0000,0000,,Главное не спешить.
Dialogue: 0,0:03:23.28,0:03:28.20,Default,,0000,0000,0000,,Как ни спеши, сегодняшний день пройдёт и наступит завтра.
Dialogue: 0,0:03:28.70,0:03:31.66,Default,,0000,0000,0000,,Это и есть счастье.
Dialogue: 0,0:03:32.12,0:03:32.79,Default,,0000,0000,0000,,Не так ли?
Dialogue: 0,0:03:33.45,0:03:35.00,Default,,0000,0000,0000,,Запомнила?
Dialogue: 0,0:03:37.71,0:03:40.00,Default,,0000,0000,0000,,Счастье?
Dialogue: 0,0:03:41.34,0:03:44.51,Default,,0000,0000,0000,,Он говорил, что будет счастлив,
Dialogue: 0,0:03:44.51,0:03:46.59,Default,,0000,0000,0000,,если я буду ждать его на вокзале.
Dialogue: 0,0:03:47.05,0:03:49.01,Default,,0000,0000,0000,,Мартин?
Dialogue: 0,0:03:54.18,0:03:56.52,Default,,0000,0000,0000,,Люди такие странные.
Dialogue: 0,0:03:57.27,0:03:59.77,Default,,0000,0000,0000,,Печаль забывается
Dialogue: 0,0:04:00.06,0:04:02.69,Default,,0000,0000,0000,,и остаются лишь хорошие воспоминания.
Dialogue: 0,0:04:03.61,0:04:04.90,Default,,0000,0000,0000,,Вам не кажется,
Dialogue: 0,0:04:04.90,0:04:06.57,Default,,0000,0000,0000,,что это так удобно.
Dialogue: 0,0:04:09.24,0:04:11.53,Default,,0000,0000,0000,,Поэтому мы продолжаем жить.
Dialogue: 0,0:04:19.87,0:04:21.04,Default,,0000,0000,0000,,Позвольте познакомить.
Dialogue: 0,0:04:21.79,0:04:23.96,Default,,0000,0000,0000,,Это адвокат пан Вардеман.
Dialogue: 0,0:04:24.46,0:04:27.34,Default,,0000,0000,0000,,Он доказал вашу невиновность,
Dialogue: 0,0:04:27.67,0:04:28.63,Default,,0000,0000,0000,,пан Гриммер.
Dialogue: 0,0:04:30.30,0:04:33.85,Default,,0000,0000,0000,,Я узнал о вас всё что смог.
Dialogue: 0,0:04:34.72,0:04:37.22,Default,,0000,0000,0000,,Выпускник 511-го детдома.
Dialogue: 0,0:04:37.73,0:04:41.27,Default,,0000,0000,0000,,Агент разведки ГДР, работавший под прикрытием журналиста
Dialogue: 0,0:04:41.27,0:04:42.81,Default,,0000,0000,0000,,и путешествовавший по всему миру.
Dialogue: 0,0:04:43.40,0:04:45.45,Default,,0000,0000,0000,,Позже как независимый журналист
Dialogue: 0,0:04:45.45,0:04:47.69,Default,,0000,0000,0000,,вы собирали материалы о нарушении прав человека в ГДР.
Dialogue: 0,0:04:48.61,0:04:50.15,Default,,0000,0000,0000,,В вашей большой сумке
Dialogue: 0,0:04:50.16,0:04:53.12,Default,,0000,0000,0000,,были целые горы бумаг на эту тему.
Dialogue: 0,0:04:54.28,0:04:57.20,Default,,0000,0000,0000,,Единственной загадкой осталось
Dialogue: 0,0:04:57.50,0:04:59.37,Default,,0000,0000,0000,,ваше настоящее имя.
Dialogue: 0,0:05:02.08,0:05:03.96,Default,,0000,0000,0000,,Вольфганг Гриммер.
Dialogue: 0,0:05:05.50,0:05:07.00,Default,,0000,0000,0000,,Не только имя.
Dialogue: 0,0:05:08.51,0:05:10.80,Default,,0000,0000,0000,,Он ушёл, ничего не сказав.
Dialogue: 0,0:05:11.80,0:05:12.97,Default,,0000,0000,0000,,Инспектор Рунге.
Dialogue: 0,0:05:13.43,0:05:14.85,Default,,0000,0000,0000,,Я больше не инспектор,
Dialogue: 0,0:05:14.85,0:05:16.22,Default,,0000,0000,0000,,следователь Сук.
Dialogue: 0,0:05:17.52,0:05:20.73,Default,,0000,0000,0000,,Я слышал, вы стали преподавать в полицейской академии.
Dialogue: 0,0:05:22.35,0:05:25.90,Default,,0000,0000,0000,,В последнее время я стал часто общаться с дочерью.
Dialogue: 0,0:05:26.61,0:05:29.40,Default,,0000,0000,0000,,Пускай и по электронной почте.
Dialogue: 0,0:05:30.49,0:05:34.28,Default,,0000,0000,0000,,Раньше мы жили, не общаясь друг с другом.
Dialogue: 0,0:05:35.62,0:05:38.58,Default,,0000,0000,0000,,Ничего не зная друг о друге.
Dialogue: 0,0:05:44.38,0:05:49.80,Default,,0000,0000,0000,,Как много могут рассказать люди друг другу, пока живы?
Dialogue: 0,0:05:50.97,0:05:53.47,Default,,0000,0000,0000,,Ты хотел поговорить о многом,
Dialogue: 0,0:05:54.51,0:05:57.81,Default,,0000,0000,0000,,попивая вкусное пиво.
Dialogue: 0,0:06:02.77,0:06:04.65,Default,,0000,0000,0000,,Вернёшься в Дюссельдорф?
Dialogue: 0,0:06:04.85,0:06:05.56,Default,,0000,0000,0000,,Да.
Dialogue: 0,0:06:06.06,0:06:08.11,Default,,0000,0000,0000,,Там фирма, на которую я работаю.
Dialogue: 0,0:06:08.40,0:06:09.48,Default,,0000,0000,0000,,Понятно.
Dialogue: 0,0:06:10.40,0:06:11.99,Default,,0000,0000,0000,,Ты уверена?
Dialogue: 0,0:06:11.99,0:06:14.66,Default,,0000,0000,0000,,С тем городом связано много воспоминаний...
Dialogue: 0,0:06:14.66,0:06:16.91,Default,,0000,0000,0000,,"Убегать бесполезно".
Dialogue: 0,0:06:16.91,0:06:20.79,Default,,0000,0000,0000,,"Главное - принять правду и идти вперёд".
Dialogue: 0,0:06:21.54,0:06:22.20,Default,,0000,0000,0000,,Верно?
Dialogue: 0,0:06:22.91,0:06:23.83,Default,,0000,0000,0000,,Да.
Dialogue: 0,0:06:27.34,0:06:30.25,Default,,0000,0000,0000,,Не могли бы вы избавиться от этого для меня?
Dialogue: 0,0:06:33.17,0:06:34.05,Default,,0000,0000,0000,,До свидания.
Dialogue: 0,0:06:34.34,0:06:35.93,Default,,0000,0000,0000,,Да.
Dialogue: 0,0:06:35.94,0:06:36.89,Default,,0000,0000,0000,,Береги себя.
Dialogue: 0,0:06:38.14,0:06:40.31,Default,,0000,0000,0000,,Если что-то понадобится, звони.
Dialogue: 0,0:06:40.64,0:06:44.31,Default,,0000,0000,0000,,Мы с доктором Гилленом с радостью тебе поможем.
Dialogue: 0,0:06:44.81,0:06:46.44,Default,,0000,0000,0000,,И Дитер.
Dialogue: 0,0:06:46.45,0:06:47.86,Default,,0000,0000,0000,,И он тоже.
Dialogue: 0,0:06:50.90,0:06:52.53,Default,,0000,0000,0000,,Передайте им привет от меня.
Dialogue: 0,0:06:53.24,0:06:54.03,Default,,0000,0000,0000,,Обязательно.
Dialogue: 0,0:07:01.79,0:07:05.21,Default,,0000,0000,0000,,Продолжаются слушания по делу доктора Тэнмы.
Dialogue: 0,0:07:05.58,0:07:08.25,Default,,0000,0000,0000,,До сих пор не выяснены все обстоятельства.
Dialogue: 0,0:07:11.13,0:07:13.76,Default,,0000,0000,0000,,Инспектор Рунге начинает давать показания.
Dialogue: 0,0:07:14.30,0:07:18.80,Default,,0000,0000,0000,,Самое ужасное дело о серийных убийствах за всю историю Европы?
Dialogue: 0,0:07:19.39,0:07:22.01,Default,,0000,0000,0000,,С доктора Тэнмы сняты все обвинения.
Dialogue: 0,0:07:22.02,0:07:26.85,Default,,0000,0000,0000,,Полиция приносит официальные извинения доктору Тэнме.
Dialogue: 0,0:07:27.73,0:07:30.44,Default,,0000,0000,0000,,Мотивы этого дела до сих пор не известны.
Dialogue: 0,0:07:30.82,0:07:34.69,Default,,0000,0000,0000,,Кто такой этот юноша, кого считают настоящим преступником?
Dialogue: 0,0:07:35.82,0:07:41.20,Default,,0000,0000,0000,,{\fs30}Медицинский университет Мюнстера предложил доктору Тэнме место профессора.
Dialogue: 0,0:07:41.20,0:07:44.08,Default,,0000,0000,0000,,Доктор продолжает отклонять предложение.
Dialogue: 0,0:07:44.91,0:07:48.96,Default,,0000,0000,0000,,Доктор Тэнма принимает участие в акции "Врачи без границ".
Dialogue: 0,0:07:49.83,0:07:52.09,Default,,0000,0000,0000,,Статьи становятся всё меньше.
Dialogue: 0,0:07:59.51,0:08:02.72,Default,,0000,0000,0000,,Разве не удобно люди устроены?
Dialogue: 0,0:08:05.10,0:08:06.81,Default,,0000,0000,0000,,Эй, Дитер.
Dialogue: 0,0:08:06.81,0:08:09.06,Default,,0000,0000,0000,,А ты подрос с тех пор, как мы виделись.
Dialogue: 0,0:08:09.27,0:08:13.82,Default,,0000,0000,0000,,А вы с тех пор стали ещё хуже, дядя Хеккель.
Dialogue: 0,0:08:13.82,0:08:16.82,Default,,0000,0000,0000,,А ты всё такой же наглый!
Dialogue: 0,0:08:17.11,0:08:19.82,Default,,0000,0000,0000,,Простите, мне нужно на тренировку.
Dialogue: 0,0:08:19.82,0:08:21.07,Default,,0000,0000,0000,,Мне с вами некогда.
Dialogue: 0,0:08:21.07,0:08:23.83,Default,,0000,0000,0000,,Эй! Постой!
Dialogue: 0,0:08:25.00,0:08:26.87,Default,,0000,0000,0000,,Тэнма вернулся?
Dialogue: 0,0:08:27.91,0:08:31.50,Default,,0000,0000,0000,,Не знаю, что такое "Врачи без границ",
Dialogue: 0,0:08:31.50,0:08:34.13,Default,,0000,0000,0000,,но так он никогда не разбогатеет!
Dialogue: 0,0:08:34.13,0:08:35.63,Default,,0000,0000,0000,,И его никак на месте не поймаешь!
Dialogue: 0,0:08:35.92,0:08:37.63,Default,,0000,0000,0000,,А что, если он вернулся?
Dialogue: 0,0:08:38.43,0:08:41.18,Default,,0000,0000,0000,,Я выполнил одну его просьбу.
Dialogue: 0,0:08:41.18,0:08:45.18,Default,,0000,0000,0000,,Да с моими расходами и трудами его оплата и рядом не лежала!
Dialogue: 0,0:08:45.68,0:08:47.68,Default,,0000,0000,0000,,Тэнма просил вас о чём-то?
Dialogue: 0,0:08:48.23,0:08:52.60,Default,,0000,0000,0000,,Попросил найти кое-кого, это прорву времени отняло!
Dialogue: 0,0:08:52.61,0:08:55.61,Default,,0000,0000,0000,,Мне даже у полицаев секретные бумаги пришлось красть!
Dialogue: 0,0:08:55.61,0:08:57.53,Default,,0000,0000,0000,,Кто знает, что бы было, попадись я!
Dialogue: 0,0:09:02.57,0:09:03.41,Default,,0000,0000,0000,,Эй!
Dialogue: 0,0:09:04.16,0:09:06.41,Default,,0000,0000,0000,,Передай мой счёт Тэнме!
Dialogue: 0,0:09:06.75,0:09:07.87,Default,,0000,0000,0000,,Если он не заплатит,
Dialogue: 0,0:09:07.87,0:09:11.46,Default,,0000,0000,0000,,я его снова подпольно работать заставлю!
Dialogue: 0,0:09:16.09,0:09:19.67,Name,,0000,0000,0000,,{\fs30\pos(320,400)\fad(580,500)\fscy125}Южная Франция
Dialogue: 0,0:09:27.97,0:09:29.85,Default,,0000,0000,0000,,Мы ждали вас.
Dialogue: 0,0:09:29.85,0:09:32.48,Default,,0000,0000,0000,,Давно вас не было.
Dialogue: 0,0:09:32.85,0:09:35.48,Default,,0000,0000,0000,,Простите, я был за границей.
Dialogue: 0,0:09:36.69,0:09:39.36,Default,,0000,0000,0000,,Это для всех вас.
Dialogue: 0,0:09:39.69,0:09:42.07,Default,,0000,0000,0000,,Большое спасибо.
Dialogue: 0,0:10:30.29,0:10:32.00,Default,,0000,0000,0000,,Прекрасная погода.
Dialogue: 0,0:10:32.66,0:10:35.46,Default,,0000,0000,0000,,Фотосинтез у растений.
Dialogue: 0,0:10:36.50,0:10:37.67,Default,,0000,0000,0000,,Жизнь.
Dialogue: 0,0:10:38.13,0:10:40.21,Default,,0000,0000,0000,,Бесчисленные гены.
Dialogue: 0,0:10:41.63,0:10:43.55,Default,,0000,0000,0000,,Вы знаете о Менделе?
Dialogue: 0,0:10:44.01,0:10:44.80,Default,,0000,0000,0000,,Да.
Dialogue: 0,0:10:45.22,0:10:46.72,Default,,0000,0000,0000,,Вывел законы генетики.
Dialogue: 0,0:10:47.14,0:10:52.06,Default,,0000,0000,0000,,Я училась в том же университете, что и Мендель.
Dialogue: 0,0:10:52.60,0:10:53.85,Default,,0000,0000,0000,,Университете Брно.
Dialogue: 0,0:10:54.44,0:10:57.90,Default,,0000,0000,0000,,В Моравии, на юго-востоке Чехии.
Dialogue: 0,0:10:58.15,0:10:59.48,Default,,0000,0000,0000,,Там очень красиво.
Dialogue: 0,0:10:59.82,0:11:01.48,Default,,0000,0000,0000,,Непременно побываю там.
Dialogue: 0,0:11:03.49,0:11:04.41,Default,,0000,0000,0000,,Спасибо,
Dialogue: 0,0:11:05.66,0:11:07.53,Default,,0000,0000,0000,,что не забываете обо мне.
Dialogue: 0,0:11:08.12,0:11:11.16,Default,,0000,0000,0000,,Что позволяете наслаждаться общением с вами.
Dialogue: 0,0:11:11.87,0:11:13.00,Default,,0000,0000,0000,,Что вы.
Dialogue: 0,0:11:13.71,0:11:15.83,Default,,0000,0000,0000,,Сегодня мне очень хорошо.
Dialogue: 0,0:11:16.71,0:11:19.84,Default,,0000,0000,0000,,Кажется, я готова говорить обо всём.
Dialogue: 0,0:11:25.18,0:11:27.26,Default,,0000,0000,0000,,Обо всех пережитых ужасах.
Dialogue: 0,0:11:35.73,0:11:37.87,Default,,0000,0000,0000,,Вы же хотите {\alpha&HFF&}что-то спросить у меня?
Dialogue: 0,0:11:37.87,0:11:39.77,Default,,0000,0000,0000,,Вы же хотите что-то спросить у меня?
Dialogue: 0,0:11:48.95,0:11:50.03,Default,,0000,0000,0000,,Вы...
Dialogue: 0,0:11:54.70,0:11:56.66,Default,,0000,0000,0000,,Мать близнецов, да?
Dialogue: 0,0:12:06.93,0:12:07.76,Default,,0000,0000,0000,,Да.
Dialogue: 0,0:12:13.81,0:12:15.72,Default,,0000,0000,0000,,Я любила его.
Dialogue: 0,0:12:16.69,0:12:18.98,Default,,0000,0000,0000,,Тот человек убил его.
Dialogue: 0,0:12:21.19,0:12:23.44,Default,,0000,0000,0000,,Это был его эксперимент.
Dialogue: 0,0:12:27.28,0:12:31.62,Default,,0000,0000,0000,,Я никогда не прощу его.
Dialogue: 0,0:12:37.04,0:12:38.25,Default,,0000,0000,0000,,Даже если я умру,
Dialogue: 0,0:12:38.96,0:12:42.80,Default,,0000,0000,0000,,мои будущие дети...
Dialogue: 0,0:12:43.93,0:12:46.63,Default,,0000,0000,0000,,покарают его.
Dialogue: 0,0:12:52.89,0:12:53.51,Default,,0000,0000,0000,,Не...
Dialogue: 0,0:12:55.93,0:12:58.85,Default,,0000,0000,0000,,Не отпускай меня.
Dialogue: 0,0:12:59.56,0:13:00.44,Default,,0000,0000,0000,,Не отпускай...
Dialogue: 0,0:13:09.86,0:13:13.07,Default,,0000,0000,0000,,Кто оказался настоящим монстром?
Dialogue: 0,0:13:17.12,0:13:19.05,Default,,0000,0000,0000,,Они{\alpha&HFF&} живы?
Dialogue: 0,0:13:19.05,0:13:20.58,Default,,0000,0000,0000,,Они живы?
Dialogue: 0,0:13:22.92,0:13:23.75,Default,,0000,0000,0000,,Да,
Dialogue: 0,0:13:24.09,0:13:25.13,Default,,0000,0000,0000,,у них всё хорошо.
Dialogue: 0,0:13:46.82,0:13:48.32,Default,,0000,0000,0000,,Я вспомнила.
Dialogue: 0,0:13:49.19,0:13:50.36,Default,,0000,0000,0000,,Что именно?
Dialogue: 0,0:13:51.53,0:13:54.20,Default,,0000,0000,0000,,Боюсь, я никогда больше не вспомню.
Dialogue: 0,0:13:54.91,0:13:56.99,Default,,0000,0000,0000,,Я должна сказать это именно сейчас.
Dialogue: 0,0:13:59.66,0:14:02.00,Default,,0000,0000,0000,,Я дала им имена.
Dialogue: 0,0:14:04.50,0:14:06.63,Default,,0000,0000,0000,,Их зовут...
Dialogue: 0,0:14:21.23,0:14:22.39,Default,,0000,0000,0000,,Войдите.
Dialogue: 0,0:14:35.03,0:14:37.83,Default,,0000,0000,0000,,Как обычно, опаздываете.
Dialogue: 0,0:14:38.28,0:14:40.45,Default,,0000,0000,0000,,На этот раз на 10 минут.
Dialogue: 0,0:14:43.12,0:14:44.22,Default,,0000,0000,0000,,Простите, {\alpha&HFF&}профессор Кронекер.
Dialogue: 0,0:14:44.22,0:14:45.46,Default,,0000,0000,0000,,Простите, профессор Кронекер.
Dialogue: 0,0:14:47.17,0:14:48.42,Default,,0000,0000,0000,,Ничего.
Dialogue: 0,0:14:49.21,0:14:53.17,Default,,0000,0000,0000,,Вы знаете, зачем я пригласил вас?
Dialogue: 0,0:14:54.68,0:14:57.43,Default,,0000,0000,0000,,Разговор касается вашей дипломной работы.
Dialogue: 0,0:15:02.18,0:15:03.48,Default,,0000,0000,0000,,Подойдите.
Dialogue: 0,0:15:03.48,0:15:05.31,Default,,0000,0000,0000,,Да.
Dialogue: 0,0:15:13.78,0:15:16.36,Default,,0000,0000,0000,,Мне известно о ваших бедах.
Dialogue: 0,0:15:16.74,0:15:20.99,Default,,0000,0000,0000,,Вам пришлось постараться, чтобы нагнать свой курс.
Dialogue: 0,0:15:21.62,0:15:26.00,Default,,0000,0000,0000,,Но это не оправдание моей успеваемости...
Dialogue: 0,0:15:26.29,0:15:27.62,Default,,0000,0000,0000,,Совершенно верно.
Dialogue: 0,0:15:30.84,0:15:33.42,Default,,0000,0000,0000,,Что же до вашего диплома...
Dialogue: 0,0:15:35.80,0:15:36.97,Default,,0000,0000,0000,,Превосходно.
Dialogue: 0,0:15:40.01,0:15:45.60,Default,,0000,0000,0000,,Ваша работа раскрыла тему наиболее полно из всех студенческих работ.
Dialogue: 0,0:15:49.02,0:15:50.61,Default,,0000,0000,0000,,Вы прекрасно поработали.
Dialogue: 0,0:15:51.94,0:15:54.11,Default,,0000,0000,0000,,Я горжусь вами.
Dialogue: 0,0:15:56.40,0:15:57.75,Default,,0000,0000,0000,,Бо... {\alpha&HFF&}большое спасибо.
Dialogue: 0,0:15:57.75,0:15:59.62,Default,,0000,0000,0000,,Бо... большое спасибо.
Dialogue: 0,0:16:00.41,0:16:01.91,Default,,0000,0000,0000,,Чем вы хотите заниматься?
Dialogue: 0,0:16:03.04,0:16:05.08,Default,,0000,0000,0000,,Стать адвокатом.
Dialogue: 0,0:16:07.00,0:16:10.79,Default,,0000,0000,0000,,Будем молиться, что вы сможете спасти не одну жизнь.
Dialogue: 0,0:16:11.84,0:16:12.84,Default,,0000,0000,0000,,Можете идти.
Dialogue: 0,0:16:13.63,0:16:14.42,Default,,0000,0000,0000,,Да.
Dialogue: 0,0:16:20.01,0:16:20.84,Default,,0000,0000,0000,,Но.
Dialogue: 0,0:16:24.56,0:16:27.06,Default,,0000,0000,0000,,В суде не прощают опоздания,
Dialogue: 0,0:16:28.14,0:16:30.60,Default,,0000,0000,0000,,фройляйн Нина Фортнер.
Dialogue: 0,0:16:33.07,0:16:33.90,Default,,0000,0000,0000,,Да.
Dialogue: 0,0:16:37.82,0:16:39.24,Default,,0000,0000,0000,,Алло.
Dialogue: 0,0:16:39.61,0:16:41.16,Default,,0000,0000,0000,,Дитер?
Dialogue: 0,0:16:41.49,0:16:42.91,Default,,0000,0000,0000,,Как твоя работа?
Dialogue: 0,0:16:43.20,0:16:45.04,Default,,0000,0000,0000,,Не расстраивайся, я всегда с тобой.
Dialogue: 0,0:16:45.29,0:16:46.70,Default,,0000,0000,0000,,Рада слышать.
Dialogue: 0,0:16:47.04,0:16:49.54,Default,,0000,0000,0000,,Попробуй развеселить меня в другой раз.
Dialogue: 0,0:16:49.79,0:16:52.13,Default,,0000,0000,0000,,Тебя голос выдаёт.
Dialogue: 0,0:16:52.13,0:16:52.96,Default,,0000,0000,0000,,Её приняли!
Dialogue: 0,0:16:52.96,0:16:53.63,Default,,0000,0000,0000,,Поздравляю!
Dialogue: 0,0:16:53.92,0:16:55.13,Default,,0000,0000,0000,,Спасибо.
Dialogue: 0,0:16:55.13,0:16:57.59,Default,,0000,0000,0000,,Впереди ещё много других дел.
Dialogue: 0,0:16:57.92,0:16:59.09,Default,,0000,0000,0000,,Это надо отметить!
Dialogue: 0,0:16:59.09,0:17:00.51,Default,,0000,0000,0000,,Приезжай поскорей!
Dialogue: 0,0:17:01.01,0:17:03.10,Default,,0000,0000,0000,,Я не могу прямо так сразу.
Dialogue: 0,0:17:03.39,0:17:04.85,Default,,0000,0000,0000,,Мне нужно на работу.
Dialogue: 0,0:17:04.85,0:17:06.85,Default,,0000,0000,0000,,И у меня были планы с друзьями.
Dialogue: 0,0:17:06.85,0:17:08.52,Default,,0000,0000,0000,,О чём ты?
Dialogue: 0,0:17:08.52,0:17:10.27,Default,,0000,0000,0000,,Тэнма должен скоро приехать!
Dialogue: 0,0:17:14.07,0:17:15.98,Default,,0000,0000,0000,,Он недавно звонил.
Dialogue: 0,0:17:15.98,0:17:19.90,Default,,0000,0000,0000,,Но он скоро снова уедет с Врачами без границ.
Dialogue: 0,0:17:21.61,0:17:22.36,Default,,0000,0000,0000,,Когда?
Dialogue: 0,0:17:22.74,0:17:24.37,Default,,0000,0000,0000,,Сказал, что приедет завтра.
Dialogue: 0,0:17:24.37,0:17:25.83,Default,,0000,0000,0000,,Поспеши, Нина!
Dialogue: 0,0:17:31.42,0:17:32.55,Default,,0000,0000,0000,,А, Нина.
Dialogue: 0,0:17:32.59,0:17:34.05,Default,,0000,0000,0000,,А завтра...
Dialogue: 0,0:17:34.05,0:17:35.96,Default,,0000,0000,0000,,Прости, дела!
Dialogue: 0,0:17:37.13,0:17:38.17,Default,,0000,0000,0000,,Тэнма!
Dialogue: 0,0:17:38.55,0:17:39.92,Default,,0000,0000,0000,,Тэнма вернулся!
Dialogue: 0,0:17:49.60,0:17:51.23,Default,,0000,0000,0000,,Добрый день.
Dialogue: 0,0:17:49.81,0:17:54.52,Name,,0000,0000,0000,,{\fs30\pos(320,404)\fad(560,710)\fscy125}Полицейский госпиталь Баварии
Dialogue: 0,0:17:51.48,0:17:52.69,Default,,0000,0000,0000,,Добрый.
Dialogue: 0,0:18:22.59,0:18:25.30,Default,,0000,0000,0000,,Ты спишь с тех самых пор.
Dialogue: 0,0:18:27.14,0:18:28.01,Default,,0000,0000,0000,,Ты слышишь меня?
Dialogue: 0,0:18:31.69,0:18:34.02,Default,,0000,0000,0000,,Я говорил с твоей мамой.
Dialogue: 0,0:18:35.06,0:18:36.77,Default,,0000,0000,0000,,Она любит тебя.
Dialogue: 0,0:18:39.90,0:18:42.28,Default,,0000,0000,0000,,Я узнал твоё настоящее имя.
Dialogue: 0,0:18:43.03,0:18:44.78,Default,,0000,0000,0000,,У тебя есть имя.
Dialogue: 0,0:19:08.60,0:19:09.85,Default,,0000,0000,0000,,Доктор Тэнма.
Dialogue: 0,0:19:10.60,0:19:13.14,Default,,0000,0000,0000,,Я хочу только вас спросить об этом.
Dialogue: 0,0:19:14.77,0:19:15.81,Default,,0000,0000,0000,,В тот день...
Dialogue: 0,0:19:16.65,0:19:19.36,Default,,0000,0000,0000,,Я увидел того монстра.
Dialogue: 0,0:19:31.75,0:19:32.96,Default2,,0000,0000,0000,,Нет!
Dialogue: 0,0:19:33.41,0:19:35.50,Default2,,0000,0000,0000,,Не трогайте их!
Dialogue: 0,0:19:35.75,0:19:36.96,Default2,,0000,0000,0000,,Нет!
Dialogue: 0,0:19:37.33,0:19:38.71,Default2,,0000,0000,0000,,Не подходите!
Dialogue: 0,0:19:39.84,0:19:41.80,Default2,,0000,0000,0000,,Это эксперимент.
Dialogue: 0,0:19:45.05,0:19:46.89,Default2,,0000,0000,0000,,Одного мы заберём, {\alpha&HFF&}а другого оставим.
Dialogue: 0,0:19:46.89,0:19:48.93,Default2,,0000,0000,0000,,Одного мы заберём, а другого оставим.
Dialogue: 0,0:19:50.76,0:19:52.77,Default2,,0000,0000,0000,,Это эксперимент.
Dialogue: 0,0:19:54.93,0:19:56.37,Default2,,0000,0000,0000,,Ну, {\alpha&HFF&}кого мы заберём?
Dialogue: 0,0:19:56.37,0:19:58.27,Default2,,0000,0000,0000,,Ну, кого мы заберём?
Dialogue: 0,0:20:04.07,0:20:05.32,Default2,,0000,0000,0000,,Не отпускай меня!
Dialogue: 0,0:20:05.90,0:20:07.32,Default2,,0000,0000,0000,,Не отпускай меня!
Dialogue: 0,0:20:09.62,0:20:10.91,Default2,,0000,0000,0000,,Не отпускай меня.
Dialogue: 0,0:20:11.28,0:20:12.41,Default2,,0000,0000,0000,,Не отпускай меня.
Dialogue: 0,0:20:14.00,0:20:14.91,Default2,,0000,0000,0000,,Мама.
Dialogue: 0,0:20:15.79,0:20:16.79,Default2,,0000,0000,0000,,Не...
Dialogue: 0,0:20:17.67,0:20:19.17,Default2,,0000,0000,0000,,Не отпускай меня!
Dialogue: 0,0:20:25.17,0:20:26.34,Default2,,0000,0000,0000,,Вот.
Dialogue: 0,0:20:27.26,0:20:28.05,Default2,,0000,0000,0000,,Нет,
Dialogue: 0,0:20:29.26,0:20:30.26,Default2,,0000,0000,0000,,{\fad(0,300)\t(300,1000,\fs40}вот!
Dialogue: 0,0:20:31.72,0:20:34.43,Default2,,0000,0000,0000,,{\t(\fs50)\fad(0,1000)}Нет!
Dialogue: 0,0:20:39.44,0:20:42.52,Default,,0000,0000,0000,,Мама хотела спасти меня?
Dialogue: 0,0:20:43.44,0:20:45.61,Default,,0000,0000,0000,,Или она перепутала меня с сестрой?
Dialogue: 0,0:20:47.20,0:20:48.11,Default,,0000,0000,0000,,Что же?
Dialogue: 0,0:20:48.99,0:20:51.31,Default,,0000,0000,0000,,Кто из нас не был ей нужен?
Dialogue: 0,0:20:51.31,0:20:52.17,Default,,0000,0000,0000,,Кто?
Dialogue: 0,0:21:22.36,0:21:24.44,Default,,0000,0000,0000,,Ну, мне пора.
Dialogue: 0,0:22:25.60,0:22:27.15,ending,,0000,0000,0000,,{\fad(210,910)\t(\fs30)}Да
Dialogue: 0,0:22:28.65,0:22:31.86,ending,,0000,0000,0000,,{\fad(210,210)}Теперь ты этот мир
Dialogue: 0,0:22:32.85,0:22:41.19,ending,,0000,0000,0000,,{\fad(210,210)}познаёшь пристальным взглядом
Dialogue: 0,0:22:42.14,0:22:43.26,ending,,0000,0000,0000,,{\fad(210,710)\t(\fs30)}Да
Dialogue: 0,0:22:45.00,0:22:48.20,ending,,0000,0000,0000,,{\fad(210,210)}Твои глаза
Dialogue: 0,0:22:49.33,0:22:57.79,ending,,0000,0000,0000,,{\fad(210,210)}верят в нежность
Dialogue: 0,0:23:15.32,0:23:23.46,ending,,0000,0000,0000,,{\fad(210,210)}Сделай этот мир домом для своей земли гармонии
Dialogue: 0,0:23:23.46,0:23:31.86,ending,,0000,0000,0000,,{\fad(210,210)}Сделай его домом для своей земли чистоты
Dialogue: 0,0:23:31.86,0:23:33.96,ending,,0000,0000,0000,,{\fad(210,210)}Сделай его домом
