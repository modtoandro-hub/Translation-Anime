Dialogue: 0,0:00:02.00,0:00:03.00,Default,,0000,0000,0000,,Ключ...
Dialogue: 0,0:00:05.13,0:00:06.50,Default,,0000,0000,0000,,Ключ и...{\alpha&HFF&} карта...
Dialogue: 0,0:00:06.50,0:00:08.09,Default,,0000,0000,0000,,Ключ и... карта...
Dialogue: 0,0:00:08.09,0:00:09.67,Default,,0000,0000,0000,,ПИН-код...
Dialogue: 0,0:00:10.63,0:00:12.38,Default,,0000,0000,0000,,В банковской ячейке...
Dialogue: 0,0:00:12.38,0:00:16.26,Default,,0000,0000,0000,,мои данные по эксперименту и плёнка...
Dialogue: 0,0:00:16.26,0:00:17.26,Default,,0000,0000,0000,,Плёнка?
Dialogue: 0,0:00:17.51,0:00:19.45,Default,,0000,0000,0000,,Там беседа... {\alpha&HFF&}с мальчиком...
Dialogue: 0,0:00:19.45,0:00:21.85,Default,,0000,0000,0000,,Там беседа... с мальчиком...
Dialogue: 0,0:00:21.85,0:00:24.51,Default,,0000,0000,0000,,Это - монстр,\N{\alpha&HFF&} который уничтожил 511-й детдом...
Dialogue: 0,0:00:24.51,0:00:27.00,Default,,0000,0000,0000,,Это - монстр,\N который уничтожил {\alpha&HFF&}511-й детдом...
Dialogue: 0,0:00:27.00,0:00:28.15,Default,,0000,0000,0000,,Это - монстр,\N который уничтожил 511-й детдом...
Dialogue: 0,0:01:59.24,0:02:02.62,Name,,0000,0000,0000,,{\fad(500,0)\pos(320,208)}Глава 42
Dialogue: 0,0:01:59.24,0:02:02.62,Name,,0000,0000,0000,,{\fad(500,0)\pos(325,392)\fscx120\bord8\3a&H6E&}Приключения \Nневероятного Штайнера
Dialogue: 0,0:02:03.41,0:02:05.63,Name,,0000,0000,0000,,{\pos(330,393)\fs26\fscy120}Полицейский участок Праги
Dialogue: 0,0:02:06.04,0:02:07.66,Default,,0000,0000,0000,,Сюда, пожалуйста.
Dialogue: 0,0:02:12.59,0:02:13.55,Default,,0000,0000,0000,,Инспектор Земан! {\alpha&HFF&}Я его привёл.
Dialogue: 0,0:02:13.55,0:02:14.50,Default,,0000,0000,0000,,Инспектор Земан! Я его привёл.
Dialogue: 0,0:02:19.26,0:02:20.26,Default,,0000,0000,0000,,Инспектор?
Dialogue: 0,0:02:19.97,0:02:23.80,Default2,,0000,0000,0000,,{\an8}[Филип Земан]
Dialogue: 0,0:02:27.18,0:02:30.14,Default,,0000,0000,0000,,Этот человек вчера был первым на месте убийства...
Dialogue: 0,0:02:30.98,0:02:33.19,Default,,0000,0000,0000,,А, пан Гриммер.
Dialogue: 0,0:02:33.19,0:02:36.44,Default,,0000,0000,0000,,Простите, что вам пришлось остаться на ночь в участке.
Dialogue: 0,0:02:36.44,0:02:40.36,Default,,0000,0000,0000,,Уронил вот щипчики для ногтей под стол...
Dialogue: 0,0:02:41.78,0:02:45.78,Default,,0000,0000,0000,,Если ты большой, то постоянно натыкаешься на разные предметы...
Dialogue: 0,0:02:46.74,0:02:49.25,Default,,0000,0000,0000,,О, да вы тоже большой!
Dialogue: 0,0:02:49.25,0:02:50.25,Default,,0000,0000,0000,,Да.
Dialogue: 0,0:02:50.25,0:02:52.58,Default,,0000,0000,0000,,Я тоже часто на всё натыкаюсь.
Dialogue: 0,0:02:52.58,0:02:55.71,Default,,0000,0000,0000,,Я руководитель расследования по этому делу, Земан.
Dialogue: 0,0:02:55.71,0:02:56.71,Default,,0000,0000,0000,,Гриммер.
Dialogue: 0,0:02:57.42,0:02:59.55,Default,,0000,0000,0000,,Пожалуйста, присаживайтесь.
Dialogue: 0,0:03:00.72,0:03:04.64,Default,,0000,0000,0000,,Прошу меня извинить, я до этого как раз ногти подстригал...
Dialogue: 0,0:03:04.64,0:03:05.68,Default,,0000,0000,0000,,Пожалуйста.
Dialogue: 0,0:03:06.51,0:03:08.64,Default,,0000,0000,0000,,Жена мне устроит,
Dialogue: 0,0:03:09.52,0:03:12.10,Default,,0000,0000,0000,,если я отращу ногти.
Dialogue: 0,0:03:12.10,0:03:16.36,Default,,0000,0000,0000,,Она не допускает белых полосок.
Dialogue: 0,0:03:17.40,0:03:20.36,Default,,0000,0000,0000,,Из-за этого у меня ногти того и гляди врастут.
Dialogue: 0,0:03:22.32,0:03:24.78,Default,,0000,0000,0000,,Вчера, должно быть, было ужасно.
Dialogue: 0,0:03:24.78,0:03:25.82,Default,,0000,0000,0000,,Да...
Dialogue: 0,0:03:26.78,0:03:28.91,Default,,0000,0000,0000,,Кто мог знать, что такое случится...
Dialogue: 0,0:03:29.70,0:03:33.33,Default,,0000,0000,0000,,Слышал, вы свободный журналист.
Dialogue: 0,0:03:33.33,0:03:36.75,Default,,0000,0000,0000,,Знаете что-нибудь о его прошлом?
Dialogue: 0,0:03:37.96,0:03:41.22,Default,,0000,0000,0000,,Михаил Иванович Петров...
Dialogue: 0,0:03:41.22,0:03:43.97,Default,,0000,0000,0000,,Настоящее имя - Райнхард Бирманн.
Dialogue: 0,0:03:43.97,0:03:44.97,Default,,0000,0000,0000,,Немец.
Dialogue: 0,0:03:46.01,0:03:47.43,Default,,0000,0000,0000,,После объединения Германии
Dialogue: 0,0:03:47.43,0:03:51.43,Default,,0000,0000,0000,,его обвинили в нарушении гражданских прав, интернировании,
Dialogue: 0,0:03:51.43,0:03:53.94,Default,,0000,0000,0000,,жестоком обращении с детьми и прочем.
Dialogue: 0,0:03:53.94,0:03:58.48,Default,,0000,0000,0000,,Вскоре после падения Берлинской Стены он бежал в Чехословакию.
Dialogue: 0,0:04:00.57,0:04:04.07,Default,,0000,0000,0000,,Германия хотела преследовать его в судебном порядке,
Dialogue: 0,0:04:04.07,0:04:08.28,Default,,0000,0000,0000,,но власти Чехословакии отпустили его, установив за ним наблюдение.
Dialogue: 0,0:04:08.83,0:04:10.24,Default,,0000,0000,0000,,Наблюдение?
Dialogue: 0,0:04:10.25,0:04:11.20,Default,,0000,0000,0000,,Да.
Dialogue: 0,0:04:11.20,0:04:15.50,Default,,0000,0000,0000,,Заодно с опасными лицами из бывшей СТБ Чехословакии.
Dialogue: 0,0:04:16.21,0:04:24.88,Default2,,0000,0000,0000,,{\an8}[СТБ - Служба гос.безопасности Чехословакии]
Dialogue: 0,0:04:16.21,0:04:17.75,Default,,0000,0000,0000,,СТБ?
Dialogue: 0,0:04:18.04,0:04:24.88,Default,,0000,0000,0000,,Вы же помните, как жестоко они подавляли инакомыслие во время холодной войны?
Dialogue: 0,0:04:24.88,0:04:29.76,Default,,0000,0000,0000,,Ещё они поставляли оружие по всему миру для террористических актов ультралевых.
Dialogue: 0,0:04:30.35,0:04:32.47,Default,,0000,0000,0000,,Тем не менее,
Dialogue: 0,0:04:32.48,0:04:36.98,Default,,0000,0000,0000,,поскольку разделение Чехии и Словакии и их демократизация проходили мирно,
Dialogue: 0,0:04:37.65,0:04:42.36,Default,,0000,0000,0000,,СТБ ушла в подполье без особого преследования со стороны правительства.
Dialogue: 0,0:04:42.36,0:04:44.99,Default,,0000,0000,0000,,У Петрова могли быть контакты с ними.
Dialogue: 0,0:04:47.66,0:04:53.08,Default,,0000,0000,0000,,Например, он мог продавать им информацию.
Dialogue: 0,0:04:56.50,0:04:57.46,Default,,0000,0000,0000,,Смотрите, а?
Dialogue: 0,0:04:57.46,0:04:59.04,Default,,0000,0000,0000,,Опять обрезал!
Dialogue: 0,0:05:01.30,0:05:04.76,Default,,0000,0000,0000,,Так-так... а женщину вы не видели?
Dialogue: 0,0:05:04.76,0:05:05.80,Default,,0000,0000,0000,,Женщину?
Dialogue: 0,0:05:07.55,0:05:12.18,Default,,0000,0000,0000,,Похоже, что Петрова убила молодая девушка,
Dialogue: 0,0:05:12.18,0:05:13.81,Default,,0000,0000,0000,,причем довольно симпатичная.
Dialogue: 0,0:05:14.27,0:05:18.44,Default,,0000,0000,0000,,Дети говорили, что они встретили женщину перед домом,
Dialogue: 0,0:05:18.44,0:05:20.52,Default,,0000,0000,0000,,но я никого не заметил.
Dialogue: 0,0:05:21.82,0:05:23.23,Default,,0000,0000,0000,,Понятно.
Dialogue: 0,0:05:24.24,0:05:25.24,Default,,0000,0000,0000,,Дети...
Dialogue: 0,0:05:25.70,0:05:30.03,Default,,0000,0000,0000,,Что будет с детьми, о которых заботился пан Петров?
Dialogue: 0,0:05:30.66,0:05:32.83,Default,,0000,0000,0000,,Сейчас они в участке,
Dialogue: 0,0:05:32.83,0:05:38.04,Default,,0000,0000,0000,,но сегодня их разберут по детдомам.
Dialogue: 0,0:05:39.38,0:05:40.46,Default,,0000,0000,0000,,Ясно.
Dialogue: 0,0:05:40.46,0:05:44.55,Default,,0000,0000,0000,,Мне жаль, что вы оказались во всём этом замешаны.
Dialogue: 0,0:05:44.55,0:05:45.55,Default,,0000,0000,0000,,Ничего.
Dialogue: 0,0:05:45.88,0:05:47.09,Default,,0000,0000,0000,,Кстати говоря,
Dialogue: 0,0:05:47.09,0:05:49.80,Default,,0000,0000,0000,,какую информацию вы собирали?
Dialogue: 0,0:05:50.97,0:05:54.51,Default,,0000,0000,0000,,О, как вы только что сказали,
Dialogue: 0,0:05:54.52,0:05:56.52,Default,,0000,0000,0000,,всего лишь несколько вопросов, касающихся Петрова.
Dialogue: 0,0:05:57.23,0:05:59.23,Default,,0000,0000,0000,,Узнали что-нибудь?
Dialogue: 0,0:06:00.23,0:06:02.69,Default,,0000,0000,0000,,Нет, но я почти выяснил...
Dialogue: 0,0:06:02.69,0:06:04.19,Default,,0000,0000,0000,,Ну вот, отлично!
Dialogue: 0,0:06:05.90,0:06:08.49,Default,,0000,0000,0000,,Теперь жена на меня не рассердится!
Dialogue: 0,0:06:11.20,0:06:13.12,Default,,0000,0000,0000,,Вы можете идти.
Dialogue: 0,0:06:13.12,0:06:16.29,Default,,0000,0000,0000,,Извините, что продержали вас здесь так долго.
Dialogue: 0,0:06:16.29,0:06:17.83,Default,,0000,0000,0000,,Ничего.
Dialogue: 0,0:06:21.96,0:06:23.71,Default,,0000,0000,0000,,Да, а перед смертью...
Dialogue: 0,0:06:23.71,0:06:27.92,Default,,0000,0000,0000,,Петров говорил что-нибудь?
Dialogue: 0,0:06:29.26,0:06:30.26,Default,,0000,0000,0000,,Нет.
Dialogue: 0,0:06:36.85,0:06:38.40,Default,,0000,0000,0000,,Мирослав,{\alpha&HFF&} Йозеф...
Dialogue: 0,0:06:38.40,0:06:39.35,Default,,0000,0000,0000,,Мирослав, Йозеф...
Dialogue: 0,0:06:39.35,0:06:40.89,Default,,0000,0000,0000,,А где Томаш?
Dialogue: 0,0:06:41.94,0:06:43.06,Default,,0000,0000,0000,,Здесь...
Dialogue: 0,0:06:44.69,0:06:46.73,Default,,0000,0000,0000,,Все трое в сборе.
Dialogue: 0,0:06:46.73,0:06:48.57,Default,,0000,0000,0000,,Хорошо, садитесь в машину.
Dialogue: 0,0:06:56.12,0:06:56.90,Default,,0000,0000,0000,,Давайте быстрее,{\alpha&HFF&} залезайте!
Dialogue: 0,0:06:56.90,0:06:57.70,Default,,0000,0000,0000,,Давайте быстрее, залезайте!
Dialogue: 0,0:07:10.01,0:07:11.17,Default,,0000,0000,0000,,Теперь следующие.
Dialogue: 0,0:07:11.18,0:07:13.72,Default,,0000,0000,0000,,Три человека в детский дом в Виноградах.
Dialogue: 0,0:07:13.72,0:07:15.93,Default,,0000,0000,0000,,Гонза, Антонин, Иззи.
Dialogue: 0,0:07:16.68,0:07:17.68,Default,,0000,0000,0000,,Да...
Dialogue: 0,0:07:19.10,0:07:20.43,Default,,0000,0000,0000,,Вам сейчас одиноко...
Dialogue: 0,0:07:21.31,0:07:24.81,Default,,0000,0000,0000,,Вы так хорошо жили вместе, а сейчас вас разделяют...
Dialogue: 0,0:07:28.03,0:07:30.94,Default,,0000,0000,0000,,Но вы и по раздельности будете под одним небом!
Dialogue: 0,0:07:33.57,0:07:36.45,Default,,0000,0000,0000,,Однажды вы снова сможете все вместе поиграть в футбол!
Dialogue: 0,0:07:37.29,0:07:38.99,Default,,0000,0000,0000,,Взбодрись, Антонин!
Dialogue: 0,0:07:39.00,0:07:40.95,Default,,0000,0000,0000,,Ты же главный?
Dialogue: 0,0:07:41.62,0:07:44.17,Default,,0000,0000,0000,,Ты можешь писать всем письма!
Dialogue: 0,0:07:44.17,0:07:46.46,Default,,0000,0000,0000,,Ты должен стать главным в группе и всех подбадривать!
Dialogue: 0,0:07:47.59,0:07:48.59,Default,,0000,0000,0000,,Хорошо...
Dialogue: 0,0:07:49.84,0:07:50.96,Default,,0000,0000,0000,,Именно так!
Dialogue: 0,0:08:35.72,0:08:37.64,Default,,0000,0000,0000,,Куда вам?
Dialogue: 0,0:08:38.93,0:08:41.64,Default,,0000,0000,0000,,В гостиницу "Кафка"...
Dialogue: 0,0:08:41.64,0:08:44.68,Default,,0000,0000,0000,,Но сперва в банк "Прохазка", пожалуйста.
Dialogue: 0,0:08:46.15,0:08:49.23,Default,,0000,0000,0000,,Банк "Прохазка" по дороге в гостиницу. (чеш.)
Dialogue: 0,0:08:50.40,0:08:53.99,Default,,0000,0000,0000,,Простите, я не очень хорошо говорю по-чешски...
Dialogue: 0,0:08:53.99,0:08:56.24,Default,,0000,0000,0000,,Вы говорите по-немецки или по-английски?
Dialogue: 0,0:08:57.24,0:08:58.45,Default,,0000,0000,0000,,Хороший сегодня денёк, да? (чеш.)
Dialogue: 0,0:09:03.83,0:09:05.16,Default,,0000,0000,0000,,Почему вы остановились?
Dialogue: 0,0:09:05.16,0:09:06.37,Default,,0000,0000,0000,,Это же не...
Dialogue: 0,0:09:06.37,0:09:07.71,Default,,0000,0000,0000,,Возьмём ещё пассажира. (чеш.)
Dialogue: 0,0:09:08.50,0:09:11.46,Default,,0000,0000,0000,,Довезите меня до промышленной зоны "Свобода". (чеш.)
Dialogue: 0,0:09:14.13,0:09:15.38,Default,,0000,0000,0000,,Эй, эй...
Dialogue: 0,0:09:15.38,0:09:17.97,Default,,0000,0000,0000,,Вы хотя бы спросили меня перед тем, как посадить ещё кого-нибудь...
Dialogue: 0,0:09:18.51,0:09:21.81,Default,,0000,0000,0000,,Смотрели вчера матч по телевизору? (чеш.)
Dialogue: 0,0:09:21.81,0:09:23.97,Default,,0000,0000,0000,,Да, не очень-то они сыграли (чеш.)
Dialogue: 0,0:09:38.41,0:09:39.41,Default,,0000,0000,0000,,Простите...
Dialogue: 0,0:09:39.87,0:09:42.58,Default,,0000,0000,0000,,Почему мы выехали за город?
Dialogue: 0,0:09:44.91,0:09:47.75,Default,,0000,0000,0000,,Моя гостиница в городе.
Dialogue: 0,0:09:50.54,0:09:51.54,Default,,0000,0000,0000,,Ключ.
Dialogue: 0,0:09:53.71,0:09:54.71,Default,,0000,0000,0000,,Ключ!
Dialogue: 0,0:09:55.13,0:09:56.84,Default,,0000,0000,0000,,О чем это вы?
Dialogue: 0,0:10:17.99,0:10:19.74,Default,,0000,0000,0000,,Сколько с тобой проблем! (чеш.)
Dialogue: 0,0:10:36.13,0:10:37.88,Default,,0000,0000,0000,,Он вон там! (чеш.)
Dialogue: 0,0:10:37.88,0:10:39.05,Default,,0000,0000,0000,,Держи его! (чеш.)
Dialogue: 0,0:10:59.32,0:11:00.57,Default,,0000,0000,0000,,Вы в порядке?
Dialogue: 0,0:11:01.70,0:11:06.03,Default,,0000,0000,0000,,Я поехал следом за вами, подумав, вдруг что случится.
Dialogue: 0,0:11:06.04,0:11:07.04,Default,,0000,0000,0000,,Вы целы?
Dialogue: 0,0:11:07.04,0:11:08.87,Default,,0000,0000,0000,,В порядке?
Dialogue: 0,0:11:13.50,0:11:14.50,Default,,0000,0000,0000,,Инспектор...
Dialogue: 0,0:11:14.92,0:11:18.55,Default,,0000,0000,0000,,Они, наверное, из СТБ, про которую я вам говорил.
Dialogue: 0,0:11:18.55,0:11:21.59,Default,,0000,0000,0000,,Они от вас что-то хотели?
Dialogue: 0,0:11:21.59,0:11:23.97,Default,,0000,0000,0000,,Н-нет, ничего...
Dialogue: 0,0:11:23.97,0:11:27.81,Default,,0000,0000,0000,,Не думаю, что они пошли бы на такое просто так.
Dialogue: 0,0:11:27.81,0:11:29.47,Default,,0000,0000,0000,,Нет, честно, ничего...
Dialogue: 0,0:11:30.18,0:11:32.98,Default,,0000,0000,0000,,Вы ничего не скрываете?
Dialogue: 0,0:11:34.90,0:11:35.48,Default,,0000,0000,0000,,Нет....
Dialogue: 0,0:11:35.94,0:11:38.07,Default,,0000,0000,0000,,У вас должны быть какие-нибудь мысли по этому поводу.
Dialogue: 0,0:11:38.07,0:11:40.32,Default,,0000,0000,0000,,Они действительно далеко зашли!
Dialogue: 0,0:11:40.32,0:11:41.40,Default,,0000,0000,0000,,Нет, {\alpha&HFF&}я правда не знаю...
Dialogue: 0,0:11:41.40,0:11:42.86,Default,,0000,0000,0000,,Нет, я правда не знаю...
Dialogue: 0,0:11:44.32,0:11:47.99,Default,,0000,0000,0000,,Так значит, вы уже забрали её из банковской ячейки в банке?
Dialogue: 0,0:11:50.58,0:11:51.58,Default,,0000,0000,0000,,Плёнку.
Dialogue: 0,0:11:53.83,0:11:55.21,Default,,0000,0000,0000,,Плёнку для кассетного магнитофона.
Dialogue: 0,0:12:01.01,0:12:03.72,Default,,0000,0000,0000,,Они ищут его истоки.
Dialogue: 0,0:12:05.51,0:12:06.80,Default,,0000,0000,0000,,Они?
Dialogue: 0,0:12:06.80,0:12:07.80,Default,,0000,0000,0000,,Истоки?
Dialogue: 0,0:12:09.06,0:12:11.27,Default,,0000,0000,0000,,Истоки монстра.
Dialogue: 0,0:12:11.27,0:12:12.60,Default,,0000,0000,0000,,Они стоят хорошие деньги!
Dialogue: 0,0:12:13.06,0:12:14.60,Default,,0000,0000,0000,,Монстра?..
Dialogue: 0,0:12:15.31,0:12:18.36,Default,,0000,0000,0000,,Мы прослушаем плёнку и сразу же узнаем.
Dialogue: 0,0:12:18.36,0:12:23.53,Default,,0000,0000,0000,,Узнаем, где в Чешской республике живет мать монстра.
Dialogue: 0,0:12:29.08,0:12:30.37,Default,,0000,0000,0000,,Алло.
Dialogue: 0,0:12:30.37,0:12:31.79,Default,,0000,0000,0000,,Это инспектор Земан.
Dialogue: 0,0:12:31.79,0:12:35.08,Default,,0000,0000,0000,,Этот подозреваемый в ограблении супермаркета
Dialogue: 0,0:12:35.08,0:12:36.71,Default,,0000,0000,0000,,уже сдал кого-нибудь из подельников?
Dialogue: 0,0:12:37.92,0:12:41.13,Default,,0000,0000,0000,,Понятно. Хорошая работа, следователь Сук.
Dialogue: 0,0:12:42.01,0:12:43.13,Default,,0000,0000,0000,,Я?
Dialogue: 0,0:12:43.13,0:12:46.01,Default,,0000,0000,0000,,У меня ещё остались некоторые дела.
Dialogue: 0,0:12:46.01,0:12:49.35,Default,,0000,0000,0000,,Так, я вернусь в участок примерно через час.
Dialogue: 0,0:12:49.35,0:12:50.72,Default,,0000,0000,0000,,До встречи.
Dialogue: 0,0:13:03.61,0:13:06.70,Default,,0000,0000,0000,,Если ты не прекратишь, он вообще говорить не сможет.
Dialogue: 0,0:13:11.41,0:13:14.20,Default,,0000,0000,0000,,А теперь готовы говорить?
Dialogue: 0,0:13:16.87,0:13:18.71,Default,,0000,0000,0000,,Где ключ?
Dialogue: 0,0:13:23.71,0:13:27.22,Default,,0000,0000,0000,,П-понятия не имею, о чём вы говорите...
Dialogue: 0,0:13:27.64,0:13:28.59,Default,,0000,0000,0000,,Ах ты!..
Dialogue: 0,0:13:28.59,0:13:29.97,Default,,0000,0000,0000,,А ну, погоди пока.
Dialogue: 0,0:13:30.55,0:13:35.06,Default,,0000,0000,0000,,Хотя вы его и прячете, пан Гриммер, там для вас ничего нет.
Dialogue: 0,0:13:36.89,0:13:40.48,Default,,0000,0000,0000,,Где ключ от банковской ячейки, который вам дал Петров?
Dialogue: 0,0:13:41.69,0:13:45.99,Default,,0000,0000,0000,,Я уже говорил – я не могу рассказать то, чего не знаю.
Dialogue: 0,0:13:46.49,0:13:47.40,Default,,0000,0000,0000,,Понятно... {\alpha&HFF&}Вы хотите денег?
Dialogue: 0,0:13:47.40,0:13:49.32,Default,,0000,0000,0000,,Понятно... Вы хотите денег?
Dialogue: 0,0:13:49.32,0:13:51.53,Default,,0000,0000,0000,,Я вас слушаю.
Dialogue: 0,0:13:51.53,0:13:53.37,Default,,0000,0000,0000,,За сколько вы его продадите?
Dialogue: 0,0:13:54.25,0:13:56.41,Default,,0000,0000,0000,,Хоть я и третьесортный журналист,
Dialogue: 0,0:13:56.41,0:14:00.00,Default,,0000,0000,0000,,в подачках не нуждаюсь.
Dialogue: 0,0:14:01.92,0:14:03.50,Default,,0000,0000,0000,,Пан Гриммер...
Dialogue: 0,0:14:05.30,0:14:06.67,Default,,0000,0000,0000,,Как плохо!
Dialogue: 0,0:14:06.67,0:14:09.18,Default,,0000,0000,0000,,Посмотрите, как у вас ногти отросли!
Dialogue: 0,0:14:09.18,0:14:13.01,Default,,0000,0000,0000,,Я же говорил вам, как нервно к этому относится моя жена?
Dialogue: 0,0:14:13.60,0:14:16.35,Default,,0000,0000,0000,,Когда у вас отрастают ногти...
Dialogue: 0,0:14:26.19,0:14:28.74,Default,,0000,0000,0000,,Лучше не дёргайтесь.
Dialogue: 0,0:14:29.45,0:14:31.07,Default,,0000,0000,0000,,Иначе я обрежу ногти до мяса.
Dialogue: 0,0:14:38.66,0:14:39.58,Default,,0000,0000,0000,,Где?
Dialogue: 0,0:14:39.58,0:14:40.75,Default,,0000,0000,0000,,Где ключ?
Dialogue: 0,0:14:42.63,0:14:43.63,Default,,0000,0000,0000,,Где?
Dialogue: 0,0:14:45.38,0:14:51.05,Default,,0000,0000,0000,,Даже если вы откроете этим ключом ячейку и возьмёте плёнку и документы,
Dialogue: 0,0:14:51.05,0:14:53.60,Default,,0000,0000,0000,,они для вас бесполезны.
Dialogue: 0,0:14:54.56,0:14:59.18,Default,,0000,0000,0000,,Эта плёнка имеет значение только для их организации.
Dialogue: 0,0:14:59.18,0:15:01.35,Default,,0000,0000,0000,,Ради их целей.
Dialogue: 0,0:15:02.02,0:15:04.90,Default,,0000,0000,0000,,Ради восстановления Восточного блока!
Dialogue: 0,0:15:07.07,0:15:11.86,Default,,0000,0000,0000,,На той плёнке записан Монстр.
Dialogue: 0,0:15:11.86,0:15:14.62,Default,,0000,0000,0000,,Им нужен этот Монстр.
Dialogue: 0,0:15:18.25,0:15:20.62,Default,,0000,0000,0000,,Я слышал, что Монстр
Dialogue: 0,0:15:20.62,0:15:22.62,Default,,0000,0000,0000,,способен их объединить.
Dialogue: 0,0:15:23.08,0:15:26.63,Default,,0000,0000,0000,,Всех, кто вышел из 511-го детдома.
Dialogue: 0,0:15:30.88,0:15:34.89,Default,,0000,0000,0000,,Они хотят собрать всех воспитанников 511-го,
Dialogue: 0,0:15:34.89,0:15:39.35,Default,,0000,0000,0000,,всех, кто был воспитан в ГДР на благо и процветание коммунизма.
Dialogue: 0,0:15:39.35,0:15:42.14,Default,,0000,0000,0000,,Лучше их просто никого нет.
Dialogue: 0,0:15:43.02,0:15:47.69,Default,,0000,0000,0000,,Говорят, что Монстр захватил контроль над 511-ым детдомом,
Dialogue: 0,0:15:47.69,0:15:49.65,Default,,0000,0000,0000,,а затем уничтожил его.
Dialogue: 0,0:15:52.28,0:15:54.24,Default,,0000,0000,0000,,Он – единственный.
Dialogue: 0,0:15:54.24,0:15:56.66,Default,,0000,0000,0000,,Единственный, кто сможет объединить эту элитную группу.
Dialogue: 0,0:16:01.12,0:16:03.46,Default,,0000,0000,0000,,Так что, где ключ?
Dialogue: 0,0:16:07.80,0:16:09.75,Default,,0000,0000,0000,,Элитную группу, да?
Dialogue: 0,0:16:12.09,0:16:13.76,Default,,0000,0000,0000,,Что смешного?
Dialogue: 0,0:16:21.60,0:16:23.81,Default,,0000,0000,0000,,Чего вы хотите?
Dialogue: 0,0:16:23.81,0:16:26.35,Default,,0000,0000,0000,,Если деньги – я могу понять.
Dialogue: 0,0:16:26.36,0:16:28.11,Default,,0000,0000,0000,,Я капиталист.
Dialogue: 0,0:16:28.11,0:16:29.69,Default,,0000,0000,0000,,Я люблю деньги!
Dialogue: 0,0:16:30.19,0:16:34.15,Default,,0000,0000,0000,,Я просто хочу заработать кучу денег, продав им ключ.
Dialogue: 0,0:16:34.15,0:16:36.70,Default,,0000,0000,0000,,А что нужно вам?
Dialogue: 0,0:16:37.37,0:16:39.91,Default,,0000,0000,0000,,Социальная справедливость?
Dialogue: 0,0:16:39.91,0:16:42.70,Default,,0000,0000,0000,,Из-за этого вы бы не стали упираться!
Dialogue: 0,0:16:43.25,0:16:45.08,Default,,0000,0000,0000,,Кто вы?
Dialogue: 0,0:16:47.67,0:16:50.67,Default,,0000,0000,0000,,Вы сказали, что вы были журналистом в ГДР,
Dialogue: 0,0:16:50.67,0:16:53.63,Default,,0000,0000,0000,,но большинство из них занимались сбором информации,
Dialogue: 0,0:16:53.63,0:16:57.64,Default,,0000,0000,0000,,и многие почти наверняка были шпионами.
Dialogue: 0,0:16:57.64,0:16:59.26,Default,,0000,0000,0000,,Кто вас послал?
Dialogue: 0,0:17:03.02,0:17:05.35,Default,,0000,0000,0000,,Играете в агента 007?
Dialogue: 0,0:17:08.23,0:17:10.23,Default,,0000,0000,0000,,Привык к пыткам, говоришь?
Dialogue: 0,0:17:21.83,0:17:23.58,Default,,0000,0000,0000,,Вы ведь правда умрёте.
Dialogue: 0,0:17:26.58,0:17:28.21,Default,,0000,0000,0000,,Последний шанс.
Dialogue: 0,0:17:28.21,0:17:30.46,Default,,0000,0000,0000,,Где ключ?
Dialogue: 0,0:17:30.46,0:17:33.00,Default,,0000,0000,0000,,Вы знаете о... {\alpha&HFF&}«{\i1}Невероятном Штайнере{\i0}»?
Dialogue: 0,0:17:33.00,0:17:35.26,Default,,0000,0000,0000,,Вы знаете о... «{\i1}Невероятном Штайнере{\i0}»?
Dialogue: 0,0:17:38.39,0:17:40.18,Default,,0000,0000,0000,,В 60-ых...
Dialogue: 0,0:17:40.18,0:17:43.77,Default,,0000,0000,0000,,в ФРГ по телевидению показывали мультик...
Dialogue: 0,0:17:43.77,0:17:45.18,Default,,0000,0000,0000,,Я смотрел его тайком...
Dialogue: 0,0:17:45.18,0:17:47.10,Default,,0000,0000,0000,,даже в ГДР...
Dialogue: 0,0:17:49.90,0:17:51.19,Default,,0000,0000,0000,,Главным героем
Dialogue: 0,0:17:51.19,0:17:53.82,Default,,0000,0000,0000,,был обычный слабый парень.
Dialogue: 0,0:17:53.82,0:17:56.32,Default,,0000,0000,0000,,Но когда он был в опасности,
Dialogue: 0,0:17:57.78,0:18:01.12,Default,,0000,0000,0000,,всегда появлялась помощь.
Dialogue: 0,0:18:01.12,0:18:02.83,Default,,0000,0000,0000,,Его тайный друг...
Dialogue: 0,0:18:06.08,0:18:10.88,Default,,0000,0000,0000,,Но главный герой и не догадывался,
Dialogue: 0,0:18:10.88,0:18:13.34,Default,,0000,0000,0000,,что его тайным другом
Dialogue: 0,0:18:14.42,0:18:16.84,Default,,0000,0000,0000,,был на самом деле он сам.
Dialogue: 0,0:18:19.84,0:18:21.80,Default,,0000,0000,0000,,Главный герой,
Dialogue: 0,0:18:21.80,0:18:24.60,Default,,0000,0000,0000,,оказываясь в смертельной опасности,
Dialogue: 0,0:18:24.60,0:18:29.60,Default,,0000,0000,0000,,превращался в «{\i1}Невероятного Штайнера{\i0}», \Nна которого страшно было даже взглянуть...
Dialogue: 0,0:18:30.52,0:18:32.98,Default,,0000,0000,0000,,Прежде, чем главный герой понимал это,
Dialogue: 0,0:18:32.98,0:18:34.82,Default,,0000,0000,0000,,все плохие парни
Dialogue: 0,0:18:34.82,0:18:37.11,Default,,0000,0000,0000,,оказывались забиты насмерть.
Dialogue: 0,0:18:42.24,0:18:44.66,Default,,0000,0000,0000,,Так превращайтесь.
Dialogue: 0,0:18:44.66,0:18:46.99,Default,,0000,0000,0000,,Превращайтесь быстрее!
Dialogue: 0,0:19:03.01,0:19:05.05,Default,,0000,0000,0000,,Полейте его водой.
Dialogue: 0,0:19:21.41,0:19:23.41,Default,,0000,0000,0000,,В конце концов он расколется.
Dialogue: 0,0:19:23.41,0:19:25.87,Default,,0000,0000,0000,,Это всего лишь дело времени.
Dialogue: 0,0:19:34.21,0:19:35.71,Default,,0000,0000,0000,,Ты кто?..
Dialogue: 0,0:20:24.13,0:20:26.89,Default,,0000,0000,0000,,Зашла женщина...
Dialogue: 0,0:21:33.79,0:21:35.41,Default,,0000,0000,0000,,Женщина...
Dialogue: 0,0:21:35.41,0:21:37.00,Default,,0000,0000,0000,,Зашла...
Dialogue: 0,0:21:39.92,0:21:41.96,Default,,0000,0000,0000,,Один выстрел...
Dialogue: 0,0:21:44.80,0:21:47.38,Default,,0000,0000,0000,,Один человек застрелен...
Dialogue: 0,0:21:50.51,0:21:53.10,Default,,0000,0000,0000,,А у двух других...
Dialogue: 0,0:21:53.10,0:21:54.77,Default,,0000,0000,0000,,Нет пулевых ранений...
Dialogue: 0,0:22:14.79,0:22:17.62,Default,,0000,0000,0000,,Невероятный Штайнер?..
Dialogue: 0,0:22:20.25,0:22:22.25,Default,,0000,0000,0000,,Я снова это сделал...
Dialogue: 0,0:23:45.42,0:23:49.80,Name,,0000,0000,0000,,{\fad(1000,0)\pos(312,212)}Глава 43
Dialogue: 0,0:23:45.42,0:23:49.80,Name,,0000,0000,0000,,{\fad(1000,0)\pos(325,380)\fscx120}Следователь Сук
Dialogue: 0,0:22:25.64,0:22:27.19,ending,,0000,0000,0000,,{\fad(210,210)}Да
Dialogue: 0,0:22:28.69,0:22:31.90,ending,,0000,0000,0000,,{\fad(210,210)}Теперь ты этот мир
Dialogue: 0,0:22:32.89,0:22:41.23,ending,,0000,0000,0000,,{\fad(210,210)}познаёшь пристальным взглядом
Dialogue: 0,0:22:42.18,0:22:43.30,ending,,0000,0000,0000,,{\fad(210,210)}Да
Dialogue: 0,0:22:45.04,0:22:48.24,ending,,0000,0000,0000,,{\fad(210,210)}Твои глаза
Dialogue: 0,0:22:49.37,0:22:57.83,ending,,0000,0000,0000,,{\fad(210,210)}верят в нежность
Dialogue: 0,0:23:15.36,0:23:23.50,ending,,0000,0000,0000,,{\fad(210,210)}Сделай этот мир домом для своей земли гармонии
Dialogue: 0,0:23:23.50,0:23:31.90,ending,,0000,0000,0000,,{\fad(210,210)}Сделай его домом для своей земли чистоты
Dialogue: 0,0:23:31.90,0:23:34.00,ending,,0000,0000,0000,,{\fad(210,210)}Сделай его домом
