Dialogue: 0,0:00:06.67,0:00:09.09,Default2,,0000,0000,0000,,Подул ветер.
Dialogue: 0,0:00:09.88,0:00:11.67,Default2,,0000,0000,0000,,Термос перевернулся.
Dialogue: 0,0:00:12.63,0:00:15.01,Default2,,0000,0000,0000,,Бутерброды оказались на земле.
Dialogue: 0,0:00:16.09,0:00:17.55,Default2,,0000,0000,0000,,А он...
Dialogue: 0,0:00:21.31,0:00:23.85,Default2,,0000,0000,0000,,Улыбнулся так печально.
Dialogue: 0,0:00:32.57,0:00:34.19,Default,,0000,0000,0000,,Хотите, тётя?
Dialogue: 0,0:00:37.20,0:00:38.45,Default,,0000,0000,0000,,Эй, Франц.
Dialogue: 0,0:00:38.45,0:00:39.45,Default,,0000,0000,0000,,Это некрасиво.
Dialogue: 0,0:00:43.41,0:00:44.71,Default,,0000,0000,0000,,Спасибо.
Dialogue: 0,0:00:49.96,0:00:51.09,Default,,0000,0000,0000,,Вкусно?
Dialogue: 0,0:01:01.81,0:01:02.68,Default,,0000,0000,0000,,Пошли.
Dialogue: 0,0:01:15.82,0:01:16.90,Default,,0000,0000,0000,,Внутрь.
Dialogue: 0,0:01:27.79,0:01:29.38,Default,,0000,0000,0000,,Алло?
Dialogue: 0,0:01:29.96,0:01:33.67,Default,,0000,0000,0000,,Я не смогла дозвониться до адвоката Вардемана.
Dialogue: 0,0:01:33.67,0:01:34.80,Default,,0000,0000,0000,,Решила позвонить вам.
Dialogue: 0,0:01:34.80,0:01:39.39,Default2,,0000,0000,0000,,Его жена недавно родила, должно быть, он поехал к ней.
Dialogue: 0,0:01:39.80,0:01:42.52,Default2,,0000,0000,0000,,Наслышан о вас,{\alpha&HFF&} фрау Ева Хайнеман.
Dialogue: 0,0:01:42.52,0:01:44.01,Default2,,0000,0000,0000,,Наслышан о вас, фрау Ева Хайнеман.
Dialogue: 0,0:01:44.43,0:01:48.10,Default2,,0000,0000,0000,,Я с удовольствием вас выслушаю.
Dialogue: 0,0:01:48.10,0:01:49.85,Default,,0000,0000,0000,,Я хотела поговорить.
Dialogue: 0,0:01:49.85,0:01:51.40,Default2,,0000,0000,0000,,О чём?
Dialogue: 0,0:01:51.77,0:01:54.65,Default,,0000,0000,0000,,О показаниях, доказывающих невиновность Тэнмы.
Dialogue: 0,0:01:54.65,0:01:57.15,Default2,,0000,0000,0000,,Вот как, это замечательно.
Dialogue: 0,0:01:58.03,0:01:59.07,Default2,,0000,0000,0000,,Так,
Dialogue: 0,0:01:59.07,0:02:01.03,Default2,,0000,0000,0000,,в каком отеле вы остановились?
Dialogue: 0,0:02:09.54,0:02:11.08,Default2,,0000,0000,0000,,Хорошо.
Dialogue: 0,0:02:12.75,0:02:15.80,Default2,,0000,0000,0000,,Я еду к вам.
Dialogue: 0,0:03:58.44,0:04:02.82,Name,,0000,0000,0000,,{\fad(500,600)\pos(316,211)\fscy112}Глава 54
Dialogue: 0,0:03:58.44,0:04:02.82,Name,,0000,0000,0000,,{\fad(500,600)\pos(323,396)\fscx120}Побег
Dialogue: 0,0:04:10.53,0:04:12.62,Default,,0000,0000,0000,,Если так делать,
Dialogue: 0,0:04:12.62,0:04:15.54,Default,,0000,0000,0000,,они меня просто объедут.
Dialogue: 0,0:04:16.62,0:04:18.37,Default,,0000,0000,0000,,Появляется машина,
Dialogue: 0,0:04:18.96,0:04:20.37,Default,,0000,0000,0000,,я падаю.
Dialogue: 0,0:04:20.92,0:04:22.17,Default,,0000,0000,0000,,Появляется,
Dialogue: 0,0:04:22.17,0:04:23.29,Default,,0000,0000,0000,,падаю.
Dialogue: 0,0:04:23.80,0:04:25.71,Default,,0000,0000,0000,,Появляется, падаю.
Dialogue: 0,0:04:26.09,0:04:28.38,Default,,0000,0000,0000,,Так будет лучше.
Dialogue: 0,0:04:28.80,0:04:30.77,Default,,0000,0000,0000,,Появляется, падаю.
Dialogue: 0,0:04:30.70,0:04:31.84,Default2,,0000,0000,0000,,Эй.
Dialogue: 0,0:04:31.34,0:04:32.22,Default,,0000,0000,0000,,Появляется, падаю.
Dialogue: 0,0:04:32.22,0:04:33.30,Default,,0000,0000,0000,,Появляется, падаю.
Dialogue: 0,0:04:32.80,0:04:34.81,Default2,,0000,0000,0000,,Слушай.
Dialogue: 0,0:04:34.81,0:04:35.80,Default,,0000,0000,0000,,Чего? {\alpha&HFF&}Я занят!
Dialogue: 0,0:04:35.80,0:04:37.60,Default,,0000,0000,0000,,Чего? Я занят!
Dialogue: 0,0:04:37.60,0:04:40.14,Default,,0000,0000,0000,,Ты правда женишься на мне сегодня?
Dialogue: 0,0:04:42.11,0:04:44.48,Default,,0000,0000,0000,,Сколько раз тебе повторять?
Dialogue: 0,0:04:44.48,0:04:46.11,Default,,0000,0000,0000,,Конечно.
Dialogue: 0,0:04:47.11,0:04:49.07,Default,,0000,0000,0000,,Правда-правда?
Dialogue: 0,0:04:49.07,0:04:50.61,Default,,0000,0000,0000,,Богом клянёшься?
Dialogue: 0,0:04:50.86,0:04:55.03,Default,,0000,0000,0000,,Да, сегодня я готов поклясться чем угодно, Хелена.
Dialogue: 0,0:04:55.99,0:04:58.66,Default,,0000,0000,0000,,Поцелуй меня, Густав.
Dialogue: 0,0:05:03.29,0:05:06.92,Default,,0000,0000,0000,,Давай продолжим в машине.
Dialogue: 0,0:05:08.72,0:05:09.30,Default,,0000,0000,0000,,Эй, {\alpha&HFF&}стой, дура!
Dialogue: 0,0:05:09.30,0:05:09.85,Default,,0000,0000,0000,,Эй, стой, {\alpha&HFF&}дура!
Dialogue: 0,0:05:09.85,0:05:10.47,Default,,0000,0000,0000,,Эй, стой, дура!
Dialogue: 0,0:05:10.47,0:05:11.68,Default,,0000,0000,0000,,Сейчас не время!
Dialogue: 0,0:05:13.55,0:05:16.68,Default,,0000,0000,0000,,Ты снова ширнулась моей дурью?
Dialogue: 0,0:05:16.68,0:05:18.47,Default,,0000,0000,0000,,Это была последняя чека!
Dialogue: 0,0:05:18.48,0:05:20.64,Default,,0000,0000,0000,,Это не я...
Dialogue: 0,0:05:20.64,0:05:24.10,Default,,0000,0000,0000,,Я видел, как ты нюхала, шлюха!
Dialogue: 0,0:05:24.11,0:05:28.82,Default,,0000,0000,0000,,Я там, значит, работу репетирую, а ты тут ширяешься?
Dialogue: 0,0:05:29.86,0:05:32.49,Default,,0000,0000,0000,,Работу? Это же пара пустяков.
Dialogue: 0,0:05:32.49,0:05:35.12,Default,,0000,0000,0000,,Тебе просто надо растянуться на дороге.
Dialogue: 0,0:05:35.12,0:05:36.99,Default,,0000,0000,0000,,Просто?
Dialogue: 0,0:05:36.99,0:05:38.95,Default,,0000,0000,0000,,Легко тебе говорить!
Dialogue: 0,0:05:38.95,0:05:41.46,Default,,0000,0000,0000,,Если я немного ошибусь, сразу отправлюсь на небеса!
Dialogue: 0,0:05:41.54,0:05:42.79,Default,,0000,0000,0000,,Умрёшь?
Dialogue: 0,0:05:42.79,0:05:44.25,Default,,0000,0000,0000,,А разве непонятно? {\alpha&HFF&}Да я сразу сдохну!
Dialogue: 0,0:05:44.25,0:05:45.58,Default,,0000,0000,0000,,А разве непонятно? Да я сразу сдохну!
Dialogue: 0,0:05:54.26,0:05:56.89,Default,,0000,0000,0000,,Не умирай!
Dialogue: 0,0:05:56.89,0:05:58.60,Default,,0000,0000,0000,,Да не, я просто так сказал.
Dialogue: 0,0:05:58.97,0:06:02.35,Default,,0000,0000,0000,,Густав умрёт!
Dialogue: 0,0:06:06.56,0:06:07.90,Default,,0000,0000,0000,,Я не умру.
Dialogue: 0,0:06:08.15,0:06:10.57,Default,,0000,0000,0000,,У меня ещё есть незаконченные дела.
Dialogue: 0,0:06:11.03,0:06:12.70,Default,,0000,0000,0000,,Какие?
Dialogue: 0,0:06:12.70,0:06:15.70,Default,,0000,0000,0000,,Обзавестись с тобой кучей детишек.
Dialogue: 0,0:06:15.95,0:06:18.95,Default,,0000,0000,0000,,Наших детей хватит на футбольную команду.
Dialogue: 0,0:06:20.16,0:06:21.54,Default,,0000,0000,0000,,Здорово, Густав.
Dialogue: 0,0:06:21.96,0:06:25.21,Default,,0000,0000,0000,,За эту работу мне заплатят кучу денег.
Dialogue: 0,0:06:25.21,0:06:27.50,Default,,0000,0000,0000,,И тогда мы поженимся.
Dialogue: 0,0:06:28.21,0:06:31.51,Default,,0000,0000,0000,,Ты воплотишь мою мечту, Хелена?
Dialogue: 0,0:06:33.55,0:06:35.76,Default,,0000,0000,0000,,Ох, Густав!
Dialogue: 0,0:06:35.76,0:06:36.17,Default,,0000,0000,0000,,Давай, {\alpha&HFF&}давай!
Dialogue: 0,0:06:36.17,0:06:36.68,Default,,0000,0000,0000,,Давай, давай!
Dialogue: 0,0:06:36.68,0:06:38.85,Default,,0000,0000,0000,,Я рожу тебе детей сколько захочешь!
Dialogue: 0,0:06:39.64,0:06:42.47,Default,,0000,0000,0000,,Сказал тебе, сейчас не время.
Dialogue: 0,0:06:42.48,0:06:45.19,Default,,0000,0000,0000,,Давай сделаем ребёнка.
Dialogue: 0,0:06:45.69,0:06:47.48,Default,,0000,0000,0000,,Потерпи.
Dialogue: 0,0:06:47.48,0:06:50.98,Default,,0000,0000,0000,,Скоро начнут повторять "{\i1}Детектива Форстера{\i0}".
Dialogue: 0,0:06:51.99,0:06:53.40,Default,,0000,0000,0000,,Появляется машина,
Dialogue: 0,0:06:53.95,0:06:55.32,Default,,0000,0000,0000,,я выпрыгиваю...
Dialogue: 0,0:06:55.32,0:06:56.45,Default,,0000,0000,0000,,И падаю.
Dialogue: 0,0:06:56.99,0:06:58.45,Default,,0000,0000,0000,,Появляется машина,
Dialogue: 0,0:06:59.16,0:07:00.45,Default,,0000,0000,0000,,я выпрыгиваю...
Dialogue: 0,0:07:00.45,0:07:01.58,Default,,0000,0000,0000,,И падаю.
Dialogue: 0,0:07:01.79,0:07:03.33,Default,,0000,0000,0000,,Появляется машина,
Dialogue: 0,0:07:03.66,0:07:04.91,Default,,0000,0000,0000,,я выпрыгиваю...
Dialogue: 0,0:07:04.91,0:07:06.04,Default,,0000,0000,0000,,И падаю.
Dialogue: 0,0:07:06.79,0:07:08.08,Default,,0000,0000,0000,,Появляется машина...
Dialogue: 0,0:07:10.84,0:07:13.26,Default2,,0000,0000,0000,,Я хочу убить
Dialogue: 0,0:07:13.59,0:07:16.13,Default2,,0000,0000,0000,,вашу бывшую невесту, {\alpha&HFF&}Еву Хайнеман.
Dialogue: 0,0:07:16.13,0:07:18.05,Default2,,0000,0000,0000,,вашу бывшую невесту, Еву Хайнеман.
Dialogue: 0,0:07:19.93,0:07:21.37,Default2,,0000,0000,0000,,Нет. {\alpha&HFF&}Нет!
Dialogue: 0,0:07:21.37,0:07:22.06,Default2,,0000,0000,0000,,Нет. Нет!
Dialogue: 0,0:07:22.47,0:07:24.31,Default2,,0000,0000,0000,,{\fad(0,1000)\t(500,1800,\fs60)}Не надо!
Dialogue: 0,0:07:39.87,0:07:42.33,Default,,0000,0000,0000,,Хорошая погодка.
Dialogue: 0,0:07:42.58,0:07:46.29,Default,,0000,0000,0000,,Такая погода, а меня запихнули в эту машину.
Dialogue: 0,0:07:46.83,0:07:50.79,Default,,0000,0000,0000,,Вместе с этим маньяком.
Dialogue: 0,0:07:50.79,0:07:53.09,Default,,0000,0000,0000,,Не везёт мне.
Dialogue: 0,0:07:53.09,0:07:54.38,Default,,0000,0000,0000,,Молчать, {\alpha&HFF&}Мильх!
Dialogue: 0,0:07:54.38,0:07:54.88,Default,,0000,0000,0000,,Молчать, Мильх!
Dialogue: 0,0:07:54.88,0:07:57.55,Default,,0000,0000,0000,,А тебе везёт.
Dialogue: 0,0:07:57.80,0:08:00.39,Default,,0000,0000,0000,,В этой обшарпанной машине,
Dialogue: 0,0:08:00.39,0:08:03.31,Default,,0000,0000,0000,,что везёт тебя в чёртову тюрьму,
Dialogue: 0,0:08:03.31,0:08:10.56,Default,,0000,0000,0000,,тебе посчастливится услышать о двенадцати побегах Гюнтера Мильха.
Dialogue: 0,0:08:11.11,0:08:13.57,Default,,0000,0000,0000,,С чего бы начать?
Dialogue: 0,0:08:13.98,0:08:17.86,Default,,0000,0000,0000,,Мне больше всего нравится побег из Крайнера.
Dialogue: 0,0:08:17.86,0:08:19.20,Default,,0000,0000,0000,,Замолчи.
Dialogue: 0,0:08:19.95,0:08:22.91,Default,,0000,0000,0000,,Да ладно вам, скучно же.
Dialogue: 0,0:08:24.58,0:08:26.58,Default,,0000,0000,0000,,Который сейчас час?
Dialogue: 0,0:08:28.54,0:08:31.42,Default,,0000,0000,0000,,Я спросил, который час?
Dialogue: 0,0:08:32.29,0:08:34.09,Default,,0000,0000,0000,,9:32
Dialogue: 0,0:08:36.09,0:08:37.38,Default,,0000,0000,0000,,Будь я на свободе,
Dialogue: 0,0:08:37.38,0:08:42.09,Default,,0000,0000,0000,,успел бы посмотреть повтор "{\i1}Детектива Форстера{\i0}".
Dialogue: 0,0:08:42.51,0:08:44.68,Default,,0000,0000,0000,,Видел этот сериал?
Dialogue: 0,0:08:48.89,0:08:50.94,Default,,0000,0000,0000,,Он очень интересный.
Dialogue: 0,0:08:51.69,0:08:54.52,Default,,0000,0000,0000,,Что ж, пора.
Dialogue: 0,0:08:55.03,0:08:57.82,Default,,0000,0000,0000,,Я займусь этой простой работой.
Dialogue: 0,0:08:57.82,0:09:00.15,Default,,0000,0000,0000,,Смотри, как я работаю.
Dialogue: 0,0:09:01.11,0:09:02.41,Default,,0000,0000,0000,,Пистолет.
Dialogue: 0,0:09:03.07,0:09:04.83,Default,,0000,0000,0000,,Ты будешь стрелять?
Dialogue: 0,0:09:04.83,0:09:05.99,Default,,0000,0000,0000,,Нет.
Dialogue: 0,0:09:05.99,0:09:07.54,Default,,0000,0000,0000,,Просто припугну.
Dialogue: 0,0:09:07.83,0:09:11.67,Default,,0000,0000,0000,,Не хочу, чтобы у наших детей были родители-убийцы.
Dialogue: 0,0:09:14.88,0:09:16.71,Default,,0000,0000,0000,,Не стреляй!
Dialogue: 0,0:09:16.71,0:09:19.38,Default,,0000,0000,0000,,Я завяжу с дурью!
Dialogue: 0,0:09:22.97,0:09:24.89,Default,,0000,0000,0000,,Я люблю тебя, Хелена.
Dialogue: 0,0:09:25.47,0:09:27.51,Default,,0000,0000,0000,,Я всё решил!
Dialogue: 0,0:09:27.52,0:09:28.68,Default,,0000,0000,0000,,Давай поженимся!
Dialogue: 0,0:09:28.98,0:09:29.81,Default,,0000,0000,0000,,Правда?
Dialogue: 0,0:09:30.64,0:09:32.69,Default,,0000,0000,0000,,Мы будем жить как все.
Dialogue: 0,0:09:32.69,0:09:35.31,Default,,0000,0000,0000,,Никаких сомнительных дел.
Dialogue: 0,0:09:35.32,0:09:36.32,Default,,0000,0000,0000,,Правда?
Dialogue: 0,0:09:36.32,0:09:37.27,Default,,0000,0000,0000,,Да.
Dialogue: 0,0:09:37.28,0:09:39.57,Default,,0000,0000,0000,,От разгуливания с оружием ничего путного не будет.
Dialogue: 0,0:09:39.57,0:09:40.86,Default,,0000,0000,0000,,Густав.
Dialogue: 0,0:09:41.20,0:09:43.60,Default,,0000,0000,0000,,Как же приятно. {\alpha&HFF&}Чёрт подери!
Dialogue: 0,0:09:43.60,0:09:44.62,Default,,0000,0000,0000,,Как же приятно. Чёрт подери!
Dialogue: 0,0:09:46.66,0:09:47.87,Default,,0000,0000,0000,,Хелена!
Dialogue: 0,0:09:47.87,0:09:49.16,Default,,0000,0000,0000,,Что?
Dialogue: 0,0:09:49.70,0:09:51.41,Default,,0000,0000,0000,,Я тебя так лю...
Dialogue: 0,0:10:05.51,0:10:06.47,Default,,0000,0000,0000,,Что это было?
Dialogue: 0,0:10:10.10,0:10:11.10,Default,,0000,0000,0000,,Что случилось?
Dialogue: 0,0:10:13.07,0:10:15.03,Default,,0000,0000,0000,,Человека...
Dialogue: 0,0:10:15.11,0:10:16.52,Default,,0000,0000,0000,,Сбил...
Dialogue: 0,0:10:16.82,0:10:18.52,Default,,0000,0000,0000,,Что?
Dialogue: 0,0:10:19.32,0:10:22.11,Default,,0000,0000,0000,,Сбил?
Dialogue: 0,0:10:24.45,0:10:26.03,Default,,0000,0000,0000,,Мильх, сидеть.
Dialogue: 0,0:10:26.32,0:10:28.78,Default,,0000,0000,0000,,Ты его сбил?
Dialogue: 0,0:10:29.08,0:10:31.79,Default,,0000,0000,0000,,Сядь, кому сказано!
Dialogue: 0,0:10:32.04,0:10:35.08,Default,,0000,0000,0000,,Это был мой приятель...
Dialogue: 0,0:10:36.13,0:10:40.42,Default,,0000,0000,0000,,План провалился, доктор Тэнма.
Dialogue: 0,0:10:42.17,0:10:46.72,Default,,0000,0000,0000,,Я научил Густава, как выбирать время и действовать...
Dialogue: 0,0:10:46.72,0:10:50.64,Default,,0000,0000,0000,,Но я один умел прокручивать такой фокус.
Dialogue: 0,0:10:50.97,0:10:56.77,Default,,0000,0000,0000,,Притвориться больным, упасть перед едущей машиной...
Dialogue: 0,0:10:58.27,0:11:02.48,Default,,0000,0000,0000,,Он был таким профаном, вы могли объехать его.
Dialogue: 0,0:11:02.78,0:11:03.62,Default,,0000,0000,0000,,И...{\alpha&HFF&} и...
Dialogue: 0,0:11:03.62,0:11:04.78,Default,,0000,0000,0000,,И... и...
Dialogue: 0,0:11:05.57,0:11:08.37,Default,,0000,0000,0000,,Как же его можно было сбить?
Dialogue: 0,0:11:09.12,0:11:11.83,Default,,0000,0000,0000,,Не понимаю, о чём ты.
Dialogue: 0,0:11:11.83,0:11:15.29,Default,,0000,0000,0000,,Пойдём проверим, он ли это.
Dialogue: 0,0:11:40.02,0:11:41.86,Default,,0000,0000,0000,,{\fad(0,600)}Густав...
Dialogue: 0,0:11:43.19,0:11:45.61,Default,,0000,0000,0000,,Эх, Густав...
Dialogue: 0,0:11:51.49,0:11:53.08,Default,,0000,0000,0000,,Хелена.
Dialogue: 0,0:11:56.37,0:11:57.54,Default,,0000,0000,0000,,Вот чёрт.
Dialogue: 0,0:11:57.54,0:11:59.75,Default,,0000,0000,0000,,Он жив?
Dialogue: 0,0:12:00.09,0:12:02.29,Default,,0000,0000,0000,,Вот дрянь.
Dialogue: 0,0:12:02.30,0:12:05.34,Default,,0000,0000,0000,,С нами же врач.
Dialogue: 0,0:12:10.35,0:12:12.05,Default,,0000,0000,0000,,Послушайте.
Dialogue: 0,0:12:12.64,0:12:13.68,Default,,0000,0000,0000,,Выходите.
Dialogue: 0,0:12:15.68,0:12:16.89,Default,,0000,0000,0000,,Эй!
Dialogue: 0,0:12:29.86,0:12:32.28,Default,,0000,0000,0000,,Густав умер...
Dialogue: 0,0:12:32.58,0:12:33.24,Default,,0000,0000,0000,,Как... {\alpha&HFF&}как он?
Dialogue: 0,0:12:33.24,0:12:34.28,Default,,0000,0000,0000,,Как... как он?
Dialogue: 0,0:12:34.62,0:12:36.25,Default,,0000,0000,0000,,Он жив?
Dialogue: 0,0:12:36.84,0:12:39.05,Default,,0000,0000,0000,,Что же я наделал?..
Dialogue: 0,0:12:39.09,0:12:41.76,Default,,0000,0000,0000,,Я проиграл...
Dialogue: 0,0:12:48.59,0:12:50.76,Default,,0000,0000,0000,,Густав!
Dialogue: 0,0:12:51.09,0:12:52.64,Default,,0000,0000,0000,,Вот чёрт...
Dialogue: 0,0:12:52.64,0:12:54.89,Default,,0000,0000,0000,,Мы сможем отписаться...
Dialogue: 0,0:12:55.18,0:12:57.40,Default,,0000,0000,0000,,Это не спустят на тормозах.
Dialogue: 0,0:12:57.10,0:12:58.89,Default2,,0000,0000,0000,,Но ведь...
Dialogue: 0,0:13:04.57,0:13:05.57,Default,,0000,0000,0000,,Ключ!
Dialogue: 0,0:13:06.36,0:13:08.69,Default,,0000,0000,0000,,Ключ от наручников!
Dialogue: 0,0:13:30.13,0:13:31.22,Default,,0000,0000,0000,,Ключ!
Dialogue: 0,0:13:31.93,0:13:33.51,Default,,0000,0000,0000,,Ключ от наручников!
Dialogue: 0,0:13:54.20,0:13:55.70,Default,,0000,0000,0000,,Вы кого-то ждёте?
Dialogue: 0,0:13:55.70,0:13:56.78,Default,,0000,0000,0000,,Да.
Dialogue: 0,0:13:56.79,0:13:58.33,Default,,0000,0000,0000,,Не желаете выпить?
Dialogue: 0,0:13:58.33,0:13:59.50,Default,,0000,0000,0000,,Скотч.
Dialogue: 0,0:14:03.08,0:14:04.04,Default,,0000,0000,0000,,Нет,
Dialogue: 0,0:14:06.46,0:14:07.67,Default,,0000,0000,0000,,Кофе.
Dialogue: 0,0:14:08.13,0:14:09.80,Default2,,0000,0000,0000,,Далее в новостях.
Dialogue: 0,0:14:09.80,0:14:14.39,Default2,,0000,0000,0000,,В Дортмунде произошёл пожар в торговом центре.
Dialogue: 0,0:14:14.80,0:14:18.10,Default2,,0000,0000,0000,,Два павильона сгорели полностью, прежде чем служащие успели включить
Dialogue: 0,0:14:18.10,0:14:19.93,Default2,,0000,0000,0000,,систему пожаротушения.
Dialogue: 0,0:14:19.93,0:14:21.98,Default2,,0000,0000,0000,,{\fad(0,400)}О жертвах не сообщается.
Dialogue: 0,0:14:21.98,0:14:23.48,Default2,,0000,0000,0000,,{\fad(300,200)\i1}Я хотела поговорить.
Dialogue: 0,0:14:23.73,0:14:25.19,Default2,,0000,0000,0000,,{\fad(300,200)\i1}О чём?
Dialogue: 0,0:14:25.44,0:14:28.19,Default2,,0000,0000,0000,,{\fad(300,200)\i1}О показаниях, доказывающих невиновность Тэнмы.
Dialogue: 0,0:14:28.61,0:14:29.82,Default2,,0000,0000,0000,,{\fad(300,200)\i1}Хорошо.
Dialogue: 0,0:14:29.82,0:14:31.94,Default2,,0000,0000,0000,,{\fad(300,200)\i1}Я еду к вам.
Dialogue: 0,0:14:32.32,0:14:34.24,Default2,,0000,0000,0000,,{\fad(300,200)\i1}Подождите меня в зале.
Dialogue: 0,0:14:38.12,0:14:40.54,Default,,0000,0000,0000,,Зачем мне помогать...
Dialogue: 0,0:14:40.91,0:14:42.25,Default,,0000,0000,0000,,его оправдать?
Dialogue: 0,0:14:42.58,0:14:44.96,Default2,,0000,0000,0000,,Мы только что получили эту новость.
Dialogue: 0,0:14:45.38,0:14:49.75,Default2,,0000,0000,0000,,Сегодня в 10 часов в пригороде Дюссельдорфа Эркрате
Dialogue: 0,0:14:49.75,0:14:55.97,Default2,,0000,0000,0000,,сбежали двое заключённых, конвоируемых в Хильден.
Dialogue: 0,0:14:56.26,0:14:58.85,Default2,,0000,0000,0000,,О деталях не сообщается,
Dialogue: 0,0:14:58.85,0:15:00.65,Default2,,0000,0000,0000,,но известно, что сбежавшие -
Dialogue: 0,0:15:00.93,0:15:04.73,Default2,,0000,0000,0000,,Гюнтер Мильх, арестованный за ограбления инкассаторских машин,
Dialogue: 0,0:15:04.73,0:15:08.11,Default2,,0000,0000,0000,,и подозреваемый в серийных убийствах Кэндзо Тэнма.
Dialogue: 0,0:15:12.15,0:15:14.53,Default2,,0000,0000,0000,,Полиция направила все силы
Dialogue: 0,0:15:14.82,0:15:18.66,Default2,,0000,0000,0000,,на поимку сбежавших.
Dialogue: 0,0:15:23.25,0:15:24.46,Default,,0000,0000,0000,,Зачем?
Dialogue: 0,0:15:25.25,0:15:27.54,Default,,0000,0000,0000,,{\fad(0,600)}Зачем ты сбежал?
Dialogue: 0,0:15:30.25,0:15:32.05,Default,,0000,0000,0000,,Да, алло?
Dialogue: 0,0:15:32.59,0:15:34.72,Default,,0000,0000,0000,,А, герр Вардеман?
Dialogue: 0,0:15:35.05,0:15:37.84,Default,,0000,0000,0000,,Да, я слышал новости.
Dialogue: 0,0:15:38.30,0:15:41.18,Default,,0000,0000,0000,,Зачем тебе надо было сбегать?
Dialogue: 0,0:15:41.93,0:15:43.14,Default,,0000,0000,0000,,Когда я...
Dialogue: 0,0:15:43.68,0:15:48.02,Default,,0000,0000,0000,,Когда я решила доказать твою невиновность.
Dialogue: 0,0:15:48.02,0:15:49.10,Default,,0000,0000,0000,,Зачем?
Dialogue: 0,0:15:49.77,0:15:53.11,Default2,,0000,0000,0000,,Не спрашивайте меня,
Dialogue: 0,0:15:53.11,0:15:56.61,Default2,,0000,0000,0000,,я сам не понимаю его поступка.
Dialogue: 0,0:15:56.61,0:15:57.36,Default2,,0000,0000,0000,,Да.
Dialogue: 0,0:15:57.36,0:16:00.24,Default2,,0000,0000,0000,,Нам стоит побывать в полиции.
Dialogue: 0,0:16:00.24,0:16:06.96,Default2,,0000,0000,0000,,Но перед этим мне нужно закончить одно дело.
Dialogue: 0,0:16:08.00,0:16:09.46,Default,,0000,0000,0000,,Понимаю.
Dialogue: 0,0:16:09.46,0:16:10.24,Default,,0000,0000,0000,,Да, {\alpha&HFF&}конечно.
Dialogue: 0,0:16:10.24,0:16:12.63,Default,,0000,0000,0000,,Да, конечно.
Dialogue: 0,0:16:12.88,0:16:16.80,Default2,,0000,0000,0000,,В такой ситуации мы должны быть рассудительны.
Dialogue: 0,0:16:17.30,0:16:18.18,Default2,,0000,0000,0000,,Да.
Dialogue: 0,0:16:18.84,0:16:19.68,Default2,,0000,0000,0000,,Да, {\alpha&HFF&}вы правы.
Dialogue: 0,0:16:19.68,0:16:21.60,Default2,,0000,0000,0000,,Да, вы правы.
Dialogue: 0,0:16:21.60,0:16:23.26,Default,,0000,0000,0000,,{\i1}Этот голос...
Dialogue: 0,0:16:23.26,0:16:25.52,Default2,,0000,0000,0000,,Нам нужны подробности...
Dialogue: 0,0:16:25.81,0:16:26.93,Default2,,0000,0000,0000,,Да.
Dialogue: 0,0:16:26.94,0:16:28.19,Default,,0000,0000,0000,,{\i1}Этот голос...
Dialogue: 0,0:16:28.19,0:16:30.65,Default2,,0000,0000,0000,,Вы совершенно правы.
Dialogue: 0,0:16:30.65,0:16:31.80,Default2,,0000,0000,0000,,Понимаю.
Dialogue: 0,0:16:31.40,0:16:32.97,Default,,0000,0000,0000,,{\i1}Этот голос!
Dialogue: 0,0:16:32.23,0:16:33.07,Default2,,0000,0000,0000,,Да, да.
Dialogue: 0,0:16:33.07,0:16:35.16,Default2,,0000,0000,0000,,Всё, что в наших силах. {\alpha&HFF&}Да.
Dialogue: 0,0:16:35.16,0:16:35.86,Default2,,0000,0000,0000,,Всё, что в наших силах. Да.
Dialogue: 0,0:16:36.95,0:16:37.78,Default,,0000,0000,0000,,Роберто!
Dialogue: 0,0:16:59.84,0:17:00.63,Default,,0000,0000,0000,,Ваш кофе...
Dialogue: 0,0:17:48.77,0:17:50.14,Default,,0000,0000,0000,,Это не мои...
Dialogue: 0,0:17:50.56,0:17:52.06,Default,,0000,0000,0000,,сигареты.
Dialogue: 0,0:17:53.90,0:17:54.81,Default,,0000,0000,0000,,Этот запах.
Dialogue: 0,0:18:04.12,0:18:05.99,Default,,0000,0000,0000,,Это его запах.
Dialogue: 0,0:18:07.37,0:18:08.87,Default,,0000,0000,0000,,Он...
Dialogue: 0,0:18:09.70,0:18:15.17,Default,,0000,0000,0000,,У меня в номере только что был Роберто.
Dialogue: 0,0:18:25.01,0:18:26.39,Default,,0000,0000,0000,,Густав!
Dialogue: 0,0:18:26.39,0:18:28.81,Default,,0000,0000,0000,,Густав умер!
Dialogue: 0,0:18:28.81,0:18:31.18,Default,,0000,0000,0000,,Хелена, он ещё жив.
Dialogue: 0,0:18:31.18,0:18:32.77,Default,,0000,0000,0000,,Но его не спасти.
Dialogue: 0,0:18:32.77,0:18:34.48,Default,,0000,0000,0000,,Удар был по голове, а крови нет.
Dialogue: 0,0:18:34.48,0:18:36.77,Default,,0000,0000,0000,,У него кровоизлияние в мозг.
Dialogue: 0,0:18:36.77,0:18:38.44,Default,,0000,0000,0000,,Так, доктор?
Dialogue: 0,0:18:40.44,0:18:42.36,Default,,0000,0000,0000,,Я тебя понимаю,
Dialogue: 0,0:18:42.36,0:18:45.66,Default,,0000,0000,0000,,но мы должны сменить машину в соседнем лесу.
Dialogue: 0,0:18:45.66,0:18:47.49,Default,,0000,0000,0000,,Густав будет мешать нам.
Dialogue: 0,0:18:47.49,0:18:49.12,Default,,0000,0000,0000,,Придётся бросить его.
Dialogue: 0,0:18:49.12,0:18:50.20,Default,,0000,0000,0000,,Нет!
Dialogue: 0,0:18:50.20,0:18:51.29,Default,,0000,0000,0000,,Езжайте дальше!
Dialogue: 0,0:18:52.16,0:18:54.54,Default,,0000,0000,0000,,У нас нет времени менять машину.
Dialogue: 0,0:18:54.54,0:18:56.01,Default,,0000,0000,0000,,Не глупите. {\alpha&HFF&}Полицаи видели её.
Dialogue: 0,0:18:56.01,0:18:58.09,Default,,0000,0000,0000,,Не глупите. Полицаи видели её.
Dialogue: 0,0:18:58.09,0:18:59.92,Default,,0000,0000,0000,,Они в момент сядут нам на хвост.
Dialogue: 0,0:19:00.30,0:19:02.97,Default,,0000,0000,0000,,Если быстро доставим его в больницу,
Dialogue: 0,0:19:02.97,0:19:04.47,Default,,0000,0000,0000,,его можно будет спасти!
Dialogue: 0,0:19:04.72,0:19:06.39,Default,,0000,0000,0000,,В больницу?
Dialogue: 0,0:19:06.39,0:19:12.39,Default,,0000,0000,0000,,Доктор, ваша решительность компенсировала мой проваленный план.
Dialogue: 0,0:19:12.39,0:19:16.02,Default,,0000,0000,0000,,Но сейчас послушайте профессионала.
Dialogue: 0,0:19:16.02,0:19:19.69,Default,,0000,0000,0000,,Мне жаль его, но Густава придётся бросить в ближайшем лесу...
Dialogue: 0,0:19:19.69,0:19:21.53,Default,,0000,0000,0000,,Поезжайте в больницу.
Dialogue: 0,0:19:21.53,0:19:23.24,Default,,0000,0000,0000,,В клинику Айслера!
Dialogue: 0,0:19:25.03,0:19:29.45,Default,,0000,0000,0000,,Там лучшие врачи и оборудование в Дюссельдорфе.
Dialogue: 0,0:19:29.45,0:19:31.33,Default,,0000,0000,0000,,Я работал там.
Dialogue: 0,0:19:31.33,0:19:31.95,Default,,0000,0000,0000,,Живо!
Dialogue: 0,0:20:03.03,0:20:05.78,Default,,0000,0000,0000,,Эта дорога ведёт к главному входу больницы.
Dialogue: 0,0:20:06.61,0:20:07.78,Default,,0000,0000,0000,,Не плакать!
Dialogue: 0,0:20:07.78,0:20:09.07,Default,,0000,0000,0000,,Как только приедете,
Dialogue: 0,0:20:09.07,0:20:12.20,Default,,0000,0000,0000,,передайте записку доктору Вагнеру.
Dialogue: 0,0:20:12.20,0:20:14.79,Default,,0000,0000,0000,,Там подробно описано всё случившееся.
Dialogue: 0,0:20:15.75,0:20:17.50,Default,,0000,0000,0000,,Густав не умрёт?
Dialogue: 0,0:20:17.83,0:20:19.54,Default,,0000,0000,0000,,Он жив!
Dialogue: 0,0:20:19.54,0:20:21.50,Default,,0000,0000,0000,,Не сдавайтесь до самого конца!
Dialogue: 0,0:20:23.71,0:20:24.84,Default,,0000,0000,0000,,Езжайте!
Dialogue: 0,0:20:31.35,0:20:32.60,Default,,0000,0000,0000,,Ну что ж.
Dialogue: 0,0:20:33.06,0:20:35.89,Default,,0000,0000,0000,,Если будем стоять здесь,
Dialogue: 0,0:20:35.89,0:20:38.60,Default,,0000,0000,0000,,нас поймают.
Dialogue: 0,0:20:38.98,0:20:40.27,Default,,0000,0000,0000,,Спасибо за всё.
Dialogue: 0,0:20:40.86,0:20:42.27,Default,,0000,0000,0000,,Что вы задумали?
Dialogue: 0,0:20:42.27,0:20:43.32,Default,,0000,0000,0000,,Куда вы?
Dialogue: 0,0:20:43.78,0:20:47.61,Default,,0000,0000,0000,,Лучше останьтесь со мной, вы же ничего не знаете.
Dialogue: 0,0:20:48.15,0:20:50.99,Default,,0000,0000,0000,,Жизнь моей знакомой в опасности.
Dialogue: 0,0:20:51.57,0:20:53.20,Default,,0000,0000,0000,,Я должен спешить.
Dialogue: 0,0:20:53.54,0:20:54.79,Default,,0000,0000,0000,,Знакомой?
Dialogue: 0,0:20:55.29,0:20:58.71,Default,,0000,0000,0000,,Неужели вы сбежали ради этого?
Dialogue: 0,0:20:59.25,0:21:02.96,Default,,0000,0000,0000,,Если доберёмся до Туниса,
Dialogue: 0,0:21:02.96,0:21:05.17,Default,,0000,0000,0000,,вы найдёте сколько угодно подружек.
Dialogue: 0,0:21:05.71,0:21:06.93,Default,,0000,0000,0000,,Спасибо. {\alpha&HFF&}Прощайте.
Dialogue: 0,0:21:06.93,0:21:08.01,Default,,0000,0000,0000,,Спасибо. Прощайте.
Dialogue: 0,0:21:12.01,0:21:13.43,Default,,0000,0000,0000,,Доктор.
Dialogue: 0,0:21:14.51,0:21:18.39,Default,,0000,0000,0000,,Вы же никого не убивали?
Dialogue: 0,0:21:20.15,0:21:21.56,Default,,0000,0000,0000,,Я стрелял один раз.
Dialogue: 0,0:21:21.94,0:21:24.15,Default,,0000,0000,0000,,Но он выжил.
Dialogue: 0,0:21:25.28,0:21:27.03,Default,,0000,0000,0000,,Это не убийство.
Dialogue: 0,0:21:27.03,0:21:30.24,Default,,0000,0000,0000,,Насколько я могу судить, вы невиновны.
Dialogue: 0,0:21:32.57,0:21:36.24,Default,,0000,0000,0000,,Но теперь у вас точно есть нарушение.
Dialogue: 0,0:21:36.54,0:21:39.08,Default,,0000,0000,0000,,Вы сбежали из тюрьмы.
Dialogue: 0,0:21:44.71,0:21:48.42,Default,,0000,0000,0000,,Встретимся как-нибудь в Тунисе, беглец с беглецом!
Dialogue: 0,0:21:48.84,0:21:50.67,Default,,0000,0000,0000,,Это отличное место!
Dialogue: 0,0:23:45.12,0:23:49.59,Name,,0000,0000,0000,,{\fad(850,0)\pos(323,215)}Глава 55
Dialogue: 0,0:23:45.12,0:23:49.59,Name,,0000,0000,0000,,{\fad(850,0)\pos(323,389)\fscx120}Номер 402
Dialogue: 0,0:22:25.60,0:22:27.15,ending,,0000,0000,0000,,{\fad(210,210)}Да
Dialogue: 0,0:22:28.65,0:22:31.86,ending,,0000,0000,0000,,{\fad(210,210)}Теперь ты этот мир
Dialogue: 0,0:22:32.85,0:22:41.19,ending,,0000,0000,0000,,{\fad(210,210)}познаёшь пристальным взглядом
Dialogue: 0,0:22:42.14,0:22:43.26,ending,,0000,0000,0000,,{\fad(210,210)}Да
Dialogue: 0,0:22:45.00,0:22:48.20,ending,,0000,0000,0000,,{\fad(210,210)}Твои глаза
Dialogue: 0,0:22:49.33,0:22:57.79,ending,,0000,0000,0000,,{\fad(210,210)}верят в нежность
Dialogue: 0,0:23:15.32,0:23:23.46,ending,,0000,0000,0000,,{\fad(210,210)}Сделай этот мир домом для своей земли гармонии
Dialogue: 0,0:23:23.46,0:23:31.86,ending,,0000,0000,0000,,{\fad(210,210)}Сделай его домом для своей земли чистоты
Dialogue: 0,0:23:31.86,0:23:33.96,ending,,0000,0000,0000,,{\fad(210,210)}Сделай его домом
