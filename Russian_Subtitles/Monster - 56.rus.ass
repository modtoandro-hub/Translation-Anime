Dialogue: 0,0:00:09.80,0:00:11.92,Default2,,0000,0000,0000,,19-ое июня.
Dialogue: 0,0:00:11.92,0:00:14.76,Default2,,0000,0000,0000,,Первая встреча с Францем Бонапартой.
Dialogue: 0,0:00:15.64,0:00:17.89,Default2,,0000,0000,0000,,РФ 17 9.
Dialogue: 0,0:00:18.35,0:00:20.39,Default2,,0000,0000,0000,,Очень спокойный человек,
Dialogue: 0,0:00:21.77,0:00:23.35,Default2,,0000,0000,0000,,с благородными манерами,
Dialogue: 0,0:00:23.35,0:00:24.73,Default2,,0000,0000,0000,,одет в хороший костюм.
Dialogue: 0,0:00:25.15,0:00:25.77,Default2,,0000,0000,0000,,Днём
Dialogue: 0,0:00:26.06,0:00:28.19,Default2,,0000,0000,0000,,пришли дети на чтение книг.
Dialogue: 0,0:00:37.78,0:00:39.16,Default,,0000,0000,0000,,Куда тебе?
Dialogue: 0,0:00:39.66,0:00:40.91,Default,,0000,0000,0000,,До границы.
Dialogue: 0,0:00:40.91,0:00:41.66,Default,,0000,0000,0000,,Какой?
Dialogue: 0,0:00:42.16,0:00:43.37,Default,,0000,0000,0000,,С Чехией.
Dialogue: 0,0:00:43.66,0:00:44.87,Default,,0000,0000,0000,,Забирайся.
Dialogue: 0,0:00:44.87,0:00:45.91,Default,,0000,0000,0000,,Спасибо.
Dialogue: 0,0:00:57.59,0:01:00.64,Default2,,0000,0000,0000,,Днём пришли дети на чтение книг.
Dialogue: 0,0:01:01.31,0:01:03.06,Default2,,0000,0000,0000,,Очень странный дом.
Dialogue: 0,0:01:03.64,0:01:05.23,Default2,,0000,0000,0000,,Дом Красных Роз.
Dialogue: 0,0:01:06.31,0:01:08.15,Default2,,0000,0000,0000,,П. Бревнов З.
Dialogue: 0,0:01:08.86,0:01:10.40,Default2,,0000,0000,0000,,Слева шпиль.
Dialogue: 0,0:01:10.77,0:01:12.27,Default2,,0000,0000,0000,,Справа флюгер.
Dialogue: 0,0:01:13.57,0:01:15.15,Default2,,0000,0000,0000,,Человеческое достоинство.
Dialogue: 0,0:01:15.49,0:01:16.53,Default2,,0000,0000,0000,,Эксперимент.
Dialogue: 0,0:01:17.16,0:01:18.74,Default2,,0000,0000,0000,,Прекрасный эксперимент.
Dialogue: 0,0:01:19.49,0:01:20.99,Default2,,0000,0000,0000,,Лишение достоинства.
Dialogue: 0,0:01:20.99,0:01:22.20,Default,,0000,0000,0000,,Откуда ты?
Dialogue: 0,0:01:23.70,0:01:25.62,Default,,0000,0000,0000,,Из какой ты страны?
Dialogue: 0,0:01:26.92,0:01:28.21,Default,,0000,0000,0000,,Из Японии.
Dialogue: 0,0:01:28.63,0:01:31.88,Default,,0000,0000,0000,,Не знаю, нравится ли вам они...
Dialogue: 0,0:01:32.75,0:01:33.84,Default,,0000,0000,0000,,Поешь.
Dialogue: 0,0:01:33.84,0:01:35.63,Default,,0000,0000,0000,,У меня остался с обеда.
Dialogue: 0,0:01:36.01,0:01:37.17,Default,,0000,0000,0000,,Спасибо.
Dialogue: 0,0:01:37.18,0:01:37.84,Default,,0000,0000,0000,,Но...
Dialogue: 0,0:01:37.84,0:01:39.30,Default,,0000,0000,0000,,Ешь.
Dialogue: 0,0:01:39.30,0:01:41.60,Default,,0000,0000,0000,,У тебя вид, словно в любой миг свалишься.
Dialogue: 0,0:01:44.31,0:01:47.94,Default,,0000,0000,0000,,Жена всё время пилит меня, чтобы похудел.
Dialogue: 0,0:01:48.40,0:01:50.27,Default,,0000,0000,0000,,Спасибо.
Dialogue: 0,0:01:50.27,0:01:51.98,Default,,0000,0000,0000,,Давай, не стесняйся.
Dialogue: 0,0:01:52.23,0:01:54.65,Default,,0000,0000,0000,,Без еды путешествие не осилишь.
Dialogue: 0,0:02:00.12,0:02:03.87,Default,,0000,0000,0000,,Мне уже пора закончить своё путешествие.
Dialogue: 0,0:03:32.33,0:03:36.02,Name,,0000,0000,0000,,{\fad(500,0)\pos(318,211)\fscy112}Глава 56
Dialogue: 0,0:03:32.33,0:03:36.02,Name,,0000,0000,0000,,{\fad(500,0)\pos(323,400)\fscx120}Бесконечное путешествие
Dialogue: 0,0:03:34.54,0:03:36.04,Default,,0000,0000,0000,,Что?
Dialogue: 0,0:03:36.33,0:03:38.00,Default,,0000,0000,0000,,Вы его отпустили?
Dialogue: 0,0:03:38.00,0:03:40.04,Default,,0000,0000,0000,,Дали Тэнме уйти?
Dialogue: 0,0:03:40.34,0:03:40.96,Default,,0000,0000,0000,,Да.
Dialogue: 0,0:03:40.96,0:03:42.42,Default,,0000,0000,0000,,Почему вы его не остановили?
Dialogue: 0,0:03:43.76,0:03:47.42,Default,,0000,0000,0000,,Вы сами понимаете, что он не остановится.
Dialogue: 0,0:03:47.84,0:03:49.13,Default,,0000,0000,0000,,Но...
Dialogue: 0,0:03:49.14,0:03:50.30,Default,,0000,0000,0000,,Кроме того,
Dialogue: 0,0:03:50.30,0:03:54.26,Default,,0000,0000,0000,,нам неизвестно, куда пропала Ева Хайнеман.
Dialogue: 0,0:03:55.10,0:03:57.52,Default,,0000,0000,0000,,Тэнма сбежал ради её спасения.
Dialogue: 0,0:04:05.78,0:04:08.40,Default,,0000,0000,0000,,Адвокат, назвавшийся Баулом...
Dialogue: 0,0:04:09.03,0:04:14.08,Default,,0000,0000,0000,,Скорее всего, это тот же человек, что пытался убить меня в моём офисе.
Dialogue: 0,0:04:14.70,0:04:16.91,Default,,0000,0000,0000,,Ему нужно было подобраться ко мне
Dialogue: 0,0:04:16.91,0:04:19.29,Default,,0000,0000,0000,,и заполучить записную книжку отца.
Dialogue: 0,0:04:20.33,0:04:23.59,Default,,0000,0000,0000,,Должно быть, в ней есть важные сведения.
Dialogue: 0,0:04:23.96,0:04:25.42,Default,,0000,0000,0000,,Мне пора.
Dialogue: 0,0:04:25.42,0:04:26.34,Default,,0000,0000,0000,,Куда?
Dialogue: 0,0:04:27.01,0:04:29.13,Default,,0000,0000,0000,,Туда, куда едет Тэнма.
Dialogue: 0,0:04:29.13,0:04:31.22,Default,,0000,0000,0000,,В Дом Красных Роз?
Dialogue: 0,0:04:31.55,0:04:32.47,Default,,0000,0000,0000,,Где он?
Dialogue: 0,0:04:33.05,0:04:36.27,Default,,0000,0000,0000,,В записях отца полно несуразицы.
Dialogue: 0,0:04:36.73,0:04:39.10,Default,,0000,0000,0000,,Но не думаю, что он их шифровал.
Dialogue: 0,0:04:39.44,0:04:41.35,Default,,0000,0000,0000,,Дом Красных Роз.
Dialogue: 0,0:04:41.35,0:04:44.48,Default,,0000,0000,0000,,"П. Бревнов З."
Dialogue: 0,0:04:44.82,0:04:46.82,Default,,0000,0000,0000,,"П" - это Прага.
Dialogue: 0,0:04:46.82,0:04:48.65,Default,,0000,0000,0000,,"З" - запад.
Dialogue: 0,0:04:48.65,0:04:51.86,Default,,0000,0000,0000,,Запад пражского района Бревнов.
Dialogue: 0,0:04:52.16,0:04:53.70,Default,,0000,0000,0000,,Там, где видны "слева шпиль",
Dialogue: 0,0:04:53.70,0:04:56.08,Default,,0000,0000,0000,,"справа флюгер".
Dialogue: 0,0:04:57.16,0:04:58.62,Default,,0000,0000,0000,,Понимаю.
Dialogue: 0,0:04:59.50,0:05:05.17,Default,,0000,0000,0000,,Нашлись бы там свидетели, чтобы мы разобрались с этим делом!
Dialogue: 0,0:05:05.92,0:05:08.59,Default,,0000,0000,0000,,Хотя сейчас уже вряд ли...
Dialogue: 0,0:05:08.59,0:05:09.38,Default,,0000,0000,0000,,Нет.
Dialogue: 0,0:05:10.93,0:05:14.01,Default,,0000,0000,0000,,"Днём пришли дети на чтение книг".
Dialogue: 0,0:05:14.89,0:05:16.85,Default,,0000,0000,0000,,Была такая запись.
Dialogue: 0,0:05:17.39,0:05:20.06,Default,,0000,0000,0000,,Те дети могут быть свидетелями.
Dialogue: 0,0:05:21.02,0:05:22.23,Default,,0000,0000,0000,,Герр Вардеман.
Dialogue: 0,0:05:23.86,0:05:27.52,Default,,0000,0000,0000,,Я осудил вас за то, что вы отпустили Тэнму.
Dialogue: 0,0:05:28.28,0:05:31.49,Default,,0000,0000,0000,,Но, будь я на вашем месте,
Dialogue: 0,0:05:31.49,0:05:33.11,Default,,0000,0000,0000,,думаю, поступил бы так же.
Dialogue: 0,0:05:34.95,0:05:36.33,Default,,0000,0000,0000,,Идёмте.
Dialogue: 0,0:05:41.33,0:05:43.33,Default,,0000,0000,0000,,Я была здесь.
Dialogue: 0,0:05:44.71,0:05:46.59,Default,,0000,0000,0000,,Жила в этом городе.
Dialogue: 0,0:05:49.80,0:05:50.96,Default,,0000,0000,0000,,И...
Dialogue: 0,0:05:54.14,0:05:54.89,Default2,,0000,0000,0000,,С возвращением.
Dialogue: 0,0:05:59.14,0:06:00.10,Default,,0000,0000,0000,,Что с тобой, Нина?
Dialogue: 0,0:06:03.52,0:06:04.85,Default,,0000,0000,0000,,Ничего.
Dialogue: 0,0:06:07.52,0:06:10.11,Default,,0000,0000,0000,,Может, больше не стоит?
Dialogue: 0,0:06:10.99,0:06:13.74,Default,,0000,0000,0000,,Мы теряемся каждый раз.
Dialogue: 0,0:06:14.45,0:06:16.70,Default,,0000,0000,0000,,Нет, я вспомню.
Dialogue: 0,0:06:17.33,0:06:21.42,Default,,0000,0000,0000,,Брат рассказал мне, что было,
Dialogue: 0,0:06:21.42,0:06:24.00,Default,,0000,0000,0000,,когда его забрали из "Трёх Жаб"....
Dialogue: 0,0:06:24.00,0:06:27.13,Default,,0000,0000,0000,,Где он проезжал и куда его забрали.
Dialogue: 0,0:06:28.38,0:06:29.59,Default,,0000,0000,0000,,Они проехали вокзал и,
Dialogue: 0,0:06:29.59,0:06:31.67,Default,,0000,0000,0000,,пока слева был виден старый город,
Dialogue: 0,0:06:31.67,0:06:34.30,Default,,0000,0000,0000,,ехал рядом с трамваем вдоль реки.
Dialogue: 0,0:06:42.73,0:06:43.68,Default,,0000,0000,0000,,Направо...
Dialogue: 0,0:06:43.69,0:06:44.94,Default2,,0000,0000,0000,,Не скрывай.
Dialogue: 0,0:06:48.27,0:06:51.03,Default2,,0000,0000,0000,,Ничего не скрывай от него.
Dialogue: 0,0:06:53.95,0:06:55.40,Default,,0000,0000,0000,,Направо?
Dialogue: 0,0:06:58.24,0:06:59.24,Default,,0000,0000,0000,,Что случилось?
Dialogue: 0,0:07:00.70,0:07:02.31,Default,,0000,0000,0000,,Н-{\alpha&HFF&}ничего...
Dialogue: 0,0:07:02.31,0:07:03.75,Default,,0000,0000,0000,,Н-ничего...
Dialogue: 0,0:07:08.84,0:07:09.92,Default,,0000,0000,0000,,Ну как?
Dialogue: 0,0:07:09.92,0:07:11.38,Default,,0000,0000,0000,,Узнаёшь?
Dialogue: 0,0:07:14.34,0:07:15.26,Default,,0000,0000,0000,,Не знаю...
Dialogue: 0,0:07:16.59,0:07:18.55,Default,,0000,0000,0000,,Может, хватит.
Dialogue: 0,0:07:18.80,0:07:22.39,Default,,0000,0000,0000,,Ты не вспомнишь то, что было так давно!
Dialogue: 0,0:07:23.56,0:07:24.93,Default,,0000,0000,0000,,Нина!
Dialogue: 0,0:07:59.22,0:08:01.10,Default,,0000,0000,0000,,Справа флюгер.
Dialogue: 0,0:08:11.27,0:08:13.86,Default,,0000,0000,0000,,Шпиль церкви слева.
Dialogue: 0,0:08:13.86,0:08:15.03,Default,,0000,0000,0000,,Нина!
Dialogue: 0,0:08:40.18,0:08:41.89,Default,,0000,0000,0000,,Дом Красных Роз!
Dialogue: 0,0:08:48.14,0:08:49.48,Default,,0000,0000,0000,,Здесь?
Dialogue: 0,0:08:50.85,0:08:51.94,Default,,0000,0000,0000,,Не знаю.
Dialogue: 0,0:08:53.57,0:08:54.57,Default,,0000,0000,0000,,Но...
Dialogue: 0,0:08:55.40,0:08:57.23,Default,,0000,0000,0000,,Мне всё знакомо.
Dialogue: 0,0:09:09.91,0:09:11.00,Default,,0000,0000,0000,,Страшно...
Dialogue: 0,0:09:24.51,0:09:25.89,Default,,0000,0000,0000,,Что это?
Dialogue: 0,0:09:37.15,0:09:40.57,Default,,0000,0000,0000,,Кажется, за стеной была дверь.
Dialogue: 0,0:10:17.11,0:10:19.32,Default,,0000,0000,0000,,Здесь ничего нет.
Dialogue: 0,0:10:21.61,0:10:22.44,Default,,0000,0000,0000,,Нина?
Dialogue: 0,0:10:22.78,0:10:23.86,Default,,0000,0000,0000,,Нина!
Dialogue: 0,0:10:24.28,0:10:25.49,Default,,0000,0000,0000,,{\fad(0,600)\t(\fs60)}Нина!
Dialogue: 0,0:10:27.74,0:10:28.74,Default,,0000,0000,0000,,Дьявол!
Dialogue: 0,0:10:29.29,0:10:30.49,Default,,0000,0000,0000,,Дьявол!
Dialogue: 0,0:10:31.00,0:10:32.04,Default,,0000,0000,0000,,Дьявол!
Dialogue: 0,0:10:32.33,0:10:34.16,Default,,0000,0000,0000,,Дьявол!
Dialogue: 0,0:10:40.92,0:10:42.80,Default,,0000,0000,0000,,Дьявол был побеждён.
Dialogue: 0,0:11:11.70,0:11:13.20,Default,,0000,0000,0000,,Как себя чувствуешь?
Dialogue: 0,0:11:20.00,0:11:22.05,Default,,0000,0000,0000,,Здравствуйте, пан Липски.
Dialogue: 0,0:11:22.51,0:11:23.96,Default,,0000,0000,0000,,Было много публики?
Dialogue: 0,0:11:24.42,0:11:26.84,Default,,0000,0000,0000,,Нет, как обычно, никого.
Dialogue: 0,0:11:27.80,0:11:29.97,Default,,0000,0000,0000,,У вас такие красивые куклы.
Dialogue: 0,0:11:31.43,0:11:34.18,Default,,0000,0000,0000,,Сейчас я делаю куклу лучше этих.
Dialogue: 0,0:11:39.02,0:11:40.81,Default,,0000,0000,0000,,Поскорее бы её увидеть!
Dialogue: 0,0:11:41.94,0:11:44.90,Default,,0000,0000,0000,,Ты её первой увидишь.
Dialogue: 0,0:11:45.65,0:11:47.53,Default,,0000,0000,0000,,Мне пора на работу.
Dialogue: 0,0:11:47.91,0:11:48.91,Default,,0000,0000,0000,,В ресторан?
Dialogue: 0,0:11:48.91,0:11:49.74,Default,,0000,0000,0000,,Да.
Dialogue: 0,0:11:49.74,0:11:52.53,Default,,0000,0000,0000,,Одним кукольным театром не прокормиться.
Dialogue: 0,0:11:52.91,0:11:56.33,Default,,0000,0000,0000,,Простите, что так долго живу у вас.
Dialogue: 0,0:11:56.62,0:11:57.93,Default,,0000,0000,0000,,Ничего,{\alpha&HFF&} не переживай.
Dialogue: 0,0:11:57.93,0:11:59.12,Default,,0000,0000,0000,,Ничего, не переживай.
Dialogue: 0,0:12:00.88,0:12:02.09,Default,,0000,0000,0000,,Пан Липски,
Dialogue: 0,0:12:03.13,0:12:04.71,Default,,0000,0000,0000,,можно вас спросить?
Dialogue: 0,0:12:05.47,0:12:06.47,Default,,0000,0000,0000,,О чём?
Dialogue: 0,0:12:07.59,0:12:09.22,Default,,0000,0000,0000,,Три месяца назад,
Dialogue: 0,0:12:09.22,0:12:12.64,Default,,0000,0000,0000,,когда вы нашли меня без сознания и отвезли в больницу...
Dialogue: 0,0:12:13.06,0:12:13.60,Default,,0000,0000,0000,,Да...
Dialogue: 0,0:12:14.68,0:12:17.02,Default,,0000,0000,0000,,Что вы делали в том доме?
Dialogue: 0,0:12:18.02,0:12:18.89,Default2,,0000,0000,0000,,Нина?
Dialogue: 0,0:12:19.23,0:12:20.06,Default2,,0000,0000,0000,,Нина!
Dialogue: 0,0:12:20.36,0:12:21.61,Default2,,0000,0000,0000,,Нина!
Dialogue: 0,0:12:22.36,0:12:24.53,Default2,,0000,0000,0000,,Ответь, Нина!
Dialogue: 0,0:12:24.78,0:12:25.90,Default2,,0000,0000,0000,,Нина!
Dialogue: 0,0:12:26.99,0:12:27.99,Default2,,0000,0000,0000,,Что случилось?
Dialogue: 0,0:12:33.08,0:12:35.33,Default,,0000,0000,0000,,В том доме ко мне
Dialogue: 0,0:12:35.33,0:12:37.58,Default,,0000,0000,0000,,приходит вдохновение.
Dialogue: 0,0:12:38.79,0:12:40.50,Default,,0000,0000,0000,,Как бы сказать...
Dialogue: 0,0:12:40.50,0:12:41.58,Default,,0000,0000,0000,,Ну...
Dialogue: 0,0:12:43.17,0:12:45.34,Default,,0000,0000,0000,,Сейчас для меня важнее...
Dialogue: 0,0:12:48.09,0:12:49.51,Default,,0000,0000,0000,,А, не бери в голову.
Dialogue: 0,0:12:49.51,0:12:51.14,Default,,0000,0000,0000,,Не волнуйся.
Dialogue: 0,0:12:52.05,0:12:54.10,Default,,0000,0000,0000,,Оставайся сколько захочешь.
Dialogue: 0,0:13:28.47,0:13:29.51,Default,,0000,0000,0000,,Нина...
Dialogue: 0,0:13:33.01,0:13:34.64,Default,,0000,0000,0000,,Можно?
Dialogue: 0,0:13:34.89,0:13:36.64,Default,,0000,0000,0000,,К-конечно.
Dialogue: 0,0:13:37.22,0:13:38.77,Default,,0000,0000,0000,,Ты хорошо себя чувствуешь, чтобы вставать?
Dialogue: 0,0:13:39.64,0:13:40.56,Default,,0000,0000,0000,,Да.
Dialogue: 0,0:13:41.02,0:13:42.27,Default,,0000,0000,0000,,Здорово!
Dialogue: 0,0:13:42.56,0:13:44.94,Default,,0000,0000,0000,,Здесь рождаются ваши куклы.
Dialogue: 0,0:13:45.61,0:13:48.28,Default,,0000,0000,0000,,Зрителей вот только нет.
Dialogue: 0,0:13:49.24,0:13:50.69,Default,,0000,0000,0000,,Что это за история?
Dialogue: 0,0:13:53.28,0:13:55.28,Default,,0000,0000,0000,,История о дьяволе.
Dialogue: 0,0:13:58.08,0:13:59.33,Default,,0000,0000,0000,,Что случилось, Нина?
Dialogue: 0,0:13:59.62,0:14:01.29,Default,,0000,0000,0000,,Продолжайте.
Dialogue: 0,0:14:02.67,0:14:05.13,Default,,0000,0000,0000,,Дьявол отправляется на поиски дракона, способного уничтожить весь мир,
Dialogue: 0,0:14:05.13,0:14:08.59,Default,,0000,0000,0000,,но чуть не погибает на полпути.
Dialogue: 0,0:14:10.47,0:14:15.64,Default,,0000,0000,0000,,Проходивший мимо юноша спасает его жизнь.
Dialogue: 0,0:14:17.39,0:14:20.31,Default,,0000,0000,0000,,Этот юноша узнаёт истинное лицо дьявола
Dialogue: 0,0:14:20.31,0:14:21.98,Default,,0000,0000,0000,,и начинает его преследовать.
Dialogue: 0,0:14:23.06,0:14:26.86,Default,,0000,0000,0000,,В конце путешествия он находит дьявола
Dialogue: 0,0:14:27.40,0:14:30.23,Default,,0000,0000,0000,,и убивает его ножом.
Dialogue: 0,0:14:32.32,0:14:34.28,Default,,0000,0000,0000,,Я думал, это интересная история,
Dialogue: 0,0:14:34.28,0:14:36.07,Default,,0000,0000,0000,,но она никому не нравится.
Dialogue: 0,0:14:37.49,0:14:39.28,Default,,0000,0000,0000,,Что-то не так, Нина?
Dialogue: 0,0:14:40.41,0:14:42.33,Default,,0000,0000,0000,,Я поступила бы так же.
Dialogue: 0,0:14:44.67,0:14:46.08,Default,,0000,0000,0000,,Я поступила бы так же.
Dialogue: 0,0:14:47.88,0:14:51.21,Default,,0000,0000,0000,,Но я не дам ему так сделать.
Dialogue: 0,0:14:52.38,0:14:53.59,Default,,0000,0000,0000,,Нина?
Dialogue: 0,0:14:53.59,0:14:55.05,Default,,0000,0000,0000,,Если ты человек,
Dialogue: 0,0:14:56.80,0:14:58.60,Default,,0000,0000,0000,,ты спасёшь дьявола.
Dialogue: 0,0:14:59.26,0:15:00.56,Default,,0000,0000,0000,,Думаешь?
Dialogue: 0,0:15:01.77,0:15:05.35,Default,,0000,0000,0000,,Мне кажется, ему бы история понравилась.
Dialogue: 0,0:15:05.35,0:15:06.44,Default,,0000,0000,0000,,Ему?
Dialogue: 0,0:15:06.44,0:15:07.56,Default,,0000,0000,0000,,На этой полке...
Dialogue: 0,0:15:08.98,0:15:10.57,Default,,0000,0000,0000,,Одни детские книги с картинками.
Dialogue: 0,0:15:11.69,0:15:13.53,Default,,0000,0000,0000,,Яков Фаробек,
Dialogue: 0,0:15:13.53,0:15:14.95,Default,,0000,0000,0000,,Клаус Поппе,
Dialogue: 0,0:15:15.41,0:15:16.57,Default,,0000,0000,0000,,Эмиль Себе.
Dialogue: 0,0:15:18.33,0:15:20.08,Default,,0000,0000,0000,,{\i1}"Монстр, у которого не было своего имени".
Dialogue: 0,0:15:21.41,0:15:23.08,Default,,0000,0000,0000,,Ты знаешь о ней.
Dialogue: 0,0:15:24.83,0:15:27.25,Default,,0000,0000,0000,,Он написал много книг.
Dialogue: 0,0:15:27.96,0:15:29.63,Default,,0000,0000,0000,,Яков Фаробек,
Dialogue: 0,0:15:29.63,0:15:31.00,Default,,0000,0000,0000,,Клаус Поппе,
Dialogue: 0,0:15:31.00,0:15:32.38,Default,,0000,0000,0000,,Эмиль Себе.
Dialogue: 0,0:15:33.13,0:15:36.34,Default,,0000,0000,0000,,Это псевдонимы одного человека.
Dialogue: 0,0:15:37.18,0:15:40.55,Default,,0000,0000,0000,,Его звали Франц Бонапарта.
Dialogue: 0,0:15:41.22,0:15:42.67,Default,,0000,0000,0000,,Франц... {\alpha&HFF&}Бонапарта...
Dialogue: 0,0:15:42.67,0:15:43.72,Default,,0000,0000,0000,,Франц... Бонапарта...
Dialogue: 0,0:15:45.06,0:15:46.56,Default2,,0000,0000,0000,,Люди
Dialogue: 0,0:15:47.15,0:15:50.06,Default2,,0000,0000,0000,,могут стать кем угодно.
Dialogue: 0,0:15:52.36,0:15:57.36,Default,,0000,0000,0000,,Меня не брали на чтения книг, потому что я не был "высшим ребёнком".
Dialogue: 0,0:15:58.24,0:15:59.57,Default,,0000,0000,0000,,Чтения?
Dialogue: 0,0:16:00.74,0:16:05.41,Default,,0000,0000,0000,,Его чтения книг проводились в Доме Красных Роз.
Dialogue: 0,0:16:06.08,0:16:08.17,Default,,0000,0000,0000,,Я там учился.
Dialogue: 0,0:16:09.29,0:16:14.42,Default,,0000,0000,0000,,Я понял, чего он добивался.
Dialogue: 0,0:16:15.72,0:16:16.90,Default2,,0000,0000,0000,,"Сделка! {\alpha&HFF&}Заключим сделку!" -
Dialogue: 0,0:16:16.90,0:16:18.05,Default2,,0000,0000,0000,,"Сделка! Заключим сделку!" -
Dialogue: 0,0:16:18.84,0:16:20.55,Default2,,0000,0000,0000,,сказал дьявол.
Dialogue: 0,0:16:21.22,0:16:22.81,Default2,,0000,0000,0000,,"Нет! Никогда!" -
Dialogue: 0,0:16:23.47,0:16:25.81,Default2,,0000,0000,0000,,ответил ему человек с большими глазами.
Dialogue: 0,0:16:26.23,0:16:28.39,Default2,,0000,0000,0000,,"Хорошо, по рукам!" -
Dialogue: 0,0:16:28.40,0:16:30.69,Default2,,0000,0000,0000,,сказал человек с большим ртом.
Dialogue: 0,0:16:31.48,0:16:35.32,Default2,,0000,0000,0000,,Во дворе человека с большим ртом распустились цветы.
Dialogue: 0,0:16:36.19,0:16:41.82,Default2,,0000,0000,0000,,А человек с большими глазами оставался таким же бедным и продолжал голодать.
Dialogue: 0,0:16:43.03,0:16:47.66,Default2,,0000,0000,0000,,Человек с большим ртом был счастлив.
Dialogue: 0,0:16:48.04,0:16:50.58,Default2,,0000,0000,0000,,Он объедался спелыми фруктами.
Dialogue: 0,0:16:51.33,0:16:53.13,Default2,,0000,0000,0000,,Поэтому он не заметил,
Dialogue: 0,0:16:53.80,0:16:56.13,Default2,,0000,0000,0000,,как его цветы завяли.
Dialogue: 0,0:16:57.47,0:17:00.30,Default2,,0000,0000,0000,,Человек с большим ртом стоял посреди сада,
Dialogue: 0,0:17:00.30,0:17:03.89,Default2,,0000,0000,0000,,где больше не расцветут цветы, и рыдал навзрыд:
Dialogue: 0,0:17:05.60,0:17:08.73,Default2,,0000,0000,0000,,"Не надо было заключать сделку с дьяволом".
Dialogue: 0,0:17:09.98,0:17:14.48,Default2,,0000,0000,0000,,Человек с большими глазами так оголодал, что почти умирал от голода.
Dialogue: 0,0:17:15.15,0:17:18.24,Default2,,0000,0000,0000,,По его щекам катились большие слёзы, и он сказал:
Dialogue: 0,0:17:19.36,0:17:21.78,Default2,,0000,0000,0000,,"Стоило заключить сделку с дьяволом".
Dialogue: 0,0:17:22.87,0:17:24.00,Default2,,0000,0000,0000,,"Сделка! {\alpha&HFF&}Заключим сделку!" -
Dialogue: 0,0:17:24.00,0:17:25.45,Default2,,0000,0000,0000,,"Сделка! Заключим сделку!" -
Dialogue: 0,0:17:25.99,0:17:27.75,Default2,,0000,0000,0000,,сказал дьявол.
Dialogue: 0,0:17:30.71,0:17:36.17,Default,,0000,0000,0000,,"Человек с большими глазами и человек с большим ртом" Якова Фаробека.
Dialogue: 0,0:17:37.67,0:17:40.59,Default,,0000,0000,0000,,Каждую пятницу в три часа
Dialogue: 0,0:17:40.59,0:17:42.51,Default,,0000,0000,0000,,мы приходили на чтения.
Dialogue: 0,0:17:43.64,0:17:46.22,Default,,0000,0000,0000,,Мы садились вокруг него
Dialogue: 0,0:17:46.22,0:17:48.52,Default,,0000,0000,0000,,и слушали, как он читает.
Dialogue: 0,0:17:49.56,0:17:51.14,Default,,0000,0000,0000,,Ласковым голосом...
Dialogue: 0,0:17:51.69,0:17:54.36,Default,,0000,0000,0000,,Очень тихим и ласковым голосом...
Dialogue: 0,0:17:55.82,0:17:59.36,Default,,0000,0000,0000,,Дочитав сказку,
Dialogue: 0,0:17:59.36,0:18:01.65,Default,,0000,0000,0000,,он спрашивал нас:
Dialogue: 0,0:18:04.57,0:18:06.49,Default,,0000,0000,0000,,"Смысл этой истории...
Dialogue: 0,0:18:07.12,0:18:08.62,Default2,,0000,0000,0000,,Понятен?"
Dialogue: 0,0:18:10.71,0:18:13.04,Default,,0000,0000,0000,,По-понятен.
Dialogue: 0,0:18:13.33,0:18:14.21,Default,,0000,0000,0000,,Мне тоже.
Dialogue: 0,0:18:14.21,0:18:16.25,Default,,0000,0000,0000,,Прочитал её много раз.
Dialogue: 0,0:18:17.17,0:18:17.88,Default,,0000,0000,0000,,Потом...
Dialogue: 0,0:18:18.13,0:18:20.51,Default,,0000,0000,0000,,Он брал следующую книжку.
Dialogue: 0,0:18:21.59,0:18:23.43,Default,,0000,0000,0000,,Клаус Поппе,
Dialogue: 0,0:18:23.43,0:18:25.14,Default,,0000,0000,0000,,{\i1}"Бог Мира".
Dialogue: 0,0:18:26.10,0:18:29.10,Default,,0000,0000,0000,,Давайте почитаем её.
Dialogue: 0,0:18:36.77,0:18:39.27,Default,,0000,0000,0000,,Я словно впервые здесь.
Dialogue: 0,0:18:41.15,0:18:43.49,Default,,0000,0000,0000,,Это заняло много времени.
Dialogue: 0,0:18:46.24,0:18:48.95,Default,,0000,0000,0000,,Но теперь все воспоминания обретают связь.
Dialogue: 0,0:18:55.08,0:18:57.92,Default2,,0000,0000,0000,,Бог мира всегда так занят.
Dialogue: 0,0:18:57.92,0:18:59.63,Default2,,0000,0000,0000,,Ему некогда смотреться в зеркало,
Dialogue: 0,0:18:59.63,0:19:01.55,Default2,,0000,0000,0000,,ему нужно дуть в свой горн каждый день.
Dialogue: 0,0:19:02.13,0:19:05.88,Default2,,0000,0000,0000,,Горн бога мира приносит всем счастье.
Dialogue: 0,0:19:06.72,0:19:09.39,Default2,,0000,0000,0000,,У Бога мира всегда столько дел.
Dialogue: 0,0:19:09.39,0:19:11.10,Default2,,0000,0000,0000,,Ему некогда смотреться в зеркало,
Dialogue: 0,0:19:11.10,0:19:12.98,Default2,,0000,0000,0000,,он должен проливать волшебную воду.
Dialogue: 0,0:19:13.77,0:19:18.23,Default2,,0000,0000,0000,,Волшебная вода даёт жизнь зелёным горам, урожайным полям...
Dialogue: 0,0:19:18.23,0:19:20.15,Default2,,0000,0000,0000,,и ярким лугам.
Dialogue: 0,0:19:21.15,0:19:23.94,Default2,,0000,0000,0000,,Бог мира всегда так занят.
Dialogue: 0,0:19:23.95,0:19:25.70,Default2,,0000,0000,0000,,Ему некогда смотреться в зеркало,
Dialogue: 0,0:19:25.70,0:19:27.87,Default2,,0000,0000,0000,,он должен дать каждому имя.
Dialogue: 0,0:19:28.83,0:19:30.49,Default2,,0000,0000,0000,,"Твоё имя - Отто".
Dialogue: 0,0:19:31.12,0:19:33.00,Default2,,0000,0000,0000,,"А твоё - Ганс".
Dialogue: 0,0:19:33.46,0:19:35.37,Default2,,0000,0000,0000,,"Твоё - Томас".
Dialogue: 0,0:19:36.17,0:19:38.08,Default2,,0000,0000,0000,,"А твоё...
Dialogue: 0,0:19:38.38,0:19:39.34,Default2,,0000,0000,0000,,Йохан!"
Dialogue: 0,0:19:40.30,0:19:44.09,Default2,,0000,0000,0000,,В благодарность Йохан подарил Богу свою шапку.
Dialogue: 0,0:19:45.43,0:19:47.43,Default2,,0000,0000,0000,,Бог был очень рад.
Dialogue: 0,0:19:48.09,0:19:53.27,Default2,,0000,0000,0000,,Он впервые посмотрелся в зеркало, чтобы полюбоваться шапкой.
Dialogue: 0,0:19:53.93,0:19:54.98,Default2,,0000,0000,0000,,Но...
Dialogue: 0,0:19:55.98,0:19:59.40,Default2,,0000,0000,0000,,В зеркале отразился дьявол.
Dialogue: 0,0:20:00.27,0:20:02.15,Default2,,0000,0000,0000,,Дьявол сказал:
Dialogue: 0,0:20:02.36,0:20:03.73,Default2,,0000,0000,0000,,"Ты - это я,
Dialogue: 0,0:20:03.74,0:20:05.15,Default2,,0000,0000,0000,,я - это ты".
Dialogue: 0,0:20:06.45,0:20:08.95,Default2,,0000,0000,0000,,"О нет, дьявол никому
Dialogue: 0,0:20:08.95,0:20:10.82,Default2,,0000,0000,0000,,не даст жить в мире!"
Dialogue: 0,0:20:11.28,0:20:11.95,Default2,,0000,0000,0000,,Что делать?
Dialogue: 0,0:20:12.24,0:20:13.33,Default2,,0000,0000,0000,,Что мне делать?
Dialogue: 0,0:20:14.37,0:20:16.12,Default2,,0000,0000,0000,,Бог совсем запутался.
Dialogue: 0,0:20:17.71,0:20:19.29,Default,,0000,0000,0000,,Знаешь, что он сделал?
Dialogue: 0,0:20:20.59,0:20:22.25,Default,,0000,0000,0000,,Я понял.
Dialogue: 0,0:20:23.38,0:20:24.88,Default,,0000,0000,0000,,Ты догадываешься,
Dialogue: 0,0:20:24.88,0:20:27.05,Default,,0000,0000,0000,,что сделал бог?
Dialogue: 0,0:20:31.14,0:20:32.22,Default,,0000,0000,0000,,Да.
Dialogue: 0,0:20:34.97,0:20:36.43,Default,,0000,0000,0000,,Наконец мы встретились.
Dialogue: 0,0:20:38.23,0:20:39.27,Default,,0000,0000,0000,,Я дома.
Dialogue: 0,0:20:40.27,0:20:41.27,Default,,0000,0000,0000,,С возвращением.
Dialogue: 0,0:20:43.07,0:20:44.48,Default,,0000,0000,0000,,Это я, мама.
Dialogue: 0,0:20:47.36,0:20:49.78,Default,,0000,0000,0000,,Мама, даже ты не могла отличить нас.
Dialogue: 0,0:20:50.78,0:20:53.03,Default,,0000,0000,0000,,Я был ей, а она была мной.
Dialogue: 0,0:20:53.70,0:20:55.70,Default,,0000,0000,0000,,Ты - это я, я - это ты.
Dialogue: 0,0:20:56.66,0:20:58.46,Default,,0000,0000,0000,,Я понял,
Dialogue: 0,0:20:59.21,0:21:01.00,Default,,0000,0000,0000,,откуда я пришёл...
Dialogue: 0,0:21:01.46,0:21:03.00,Default,,0000,0000,0000,,И куда иду.
Dialogue: 0,0:21:05.92,0:21:08.26,Default,,0000,0000,0000,,На улице прекрасная погода,
Dialogue: 0,0:21:08.26,0:21:09.43,Default,,0000,0000,0000,,мама.
Dialogue: 0,0:21:24.07,0:21:26.19,Default,,0000,0000,0000,,Пламя поглотит всё.
Dialogue: 0,0:21:49.38,0:21:50.55,Default,,0000,0000,0000,,Я поняла...
Dialogue: 0,0:21:51.63,0:21:52.97,Default,,0000,0000,0000,,Бог...
Dialogue: 0,0:22:08.69,0:22:09.99,Default,,0000,0000,0000,,Наставил пистолет..
Dialogue: 0,0:22:11.24,0:22:12.99,Default,,0000,0000,0000,,Себе в лоб.
Dialogue: 0,0:22:21.62,0:22:23.17,Default2,,0000,0000,0000,,Стреляй в меня.
Dialogue: 0,0:23:45.54,0:23:49.84,Name,,0000,0000,0000,,{\fad(850,0)\pos(323,215)}Глава 57
Dialogue: 0,0:23:45.54,0:23:49.84,Name,,0000,0000,0000,,{\fad(850,0)\pos(325,389)\fscx120}Та ночь
Dialogue: 0,0:22:25.60,0:22:27.15,ending,,0000,0000,0000,,{\fad(210,210)}Да
Dialogue: 0,0:22:28.65,0:22:31.86,ending,,0000,0000,0000,,{\fad(210,210)}Теперь ты этот мир
Dialogue: 0,0:22:32.85,0:22:41.19,ending,,0000,0000,0000,,{\fad(210,210)}познаёшь пристальным взглядом
Dialogue: 0,0:22:42.14,0:22:43.26,ending,,0000,0000,0000,,{\fad(210,210)}Да
Dialogue: 0,0:22:45.00,0:22:48.20,ending,,0000,0000,0000,,{\fad(210,210)}Твои глаза
Dialogue: 0,0:22:49.33,0:22:57.79,ending,,0000,0000,0000,,{\fad(210,210)}верят в нежность
Dialogue: 0,0:23:15.32,0:23:23.46,ending,,0000,0000,0000,,{\fad(210,210)}Сделай этот мир домом для своей земли гармонии
Dialogue: 0,0:23:23.46,0:23:31.86,ending,,0000,0000,0000,,{\fad(210,210)}Сделай его домом для своей земли чистоты
Dialogue: 0,0:23:31.86,0:23:33.96,ending,,0000,0000,0000,,{\fad(210,210)}Сделай его домом
