Dialogue: 0,0:00:06.13,0:00:08.75,Default,,0000,0000,0000,,Твоя мать бросила тебя!
Dialogue: 0,0:00:08.75,0:00:12.67,Default,,0000,0000,0000,,Она тебя выбросила вместе с папашей-пьяницей, как мусор!
Dialogue: 0,0:00:12.67,0:00:15.43,Default,,0000,0000,0000,,Не смей вылезать из мусорного ящика!
Dialogue: 0,0:01:57.98,0:02:01.57,Name,,0000,0000,0000,,{\fad(800,0)\pos(321,209)\fscy112}Глава 70
Dialogue: 0,0:01:57.98,0:02:01.57,Name,,0000,0000,0000,,{\fad(800,0)\pos(323,400)\fscx120}Город массовой резни
Dialogue: 0,0:02:08.54,0:02:11.12,Default,,0000,0000,0000,,Извини, тебе лучше уйти.
Dialogue: 0,0:02:11.62,0:02:14.54,Default,,0000,0000,0000,,Сперва заплати по счёту, а потом приходи.
Dialogue: 0,0:02:14.54,0:02:16.08,Default,,0000,0000,0000,,Деньги?
Dialogue: 0,0:02:16.71,0:02:18.09,Default,,0000,0000,0000,,Вот.
Dialogue: 0,0:02:18.09,0:02:19.63,Default,,0000,0000,0000,,Этого хватит на сегодня.
Dialogue: 0,0:02:19.63,0:02:23.63,Default,,0000,0000,0000,,Я не стану продавать тебе выпивку за деньги твоего сына.
Dialogue: 0,0:02:23.88,0:02:24.97,Default,,0000,0000,0000,,Что?
Dialogue: 0,0:02:25.68,0:02:26.97,Default,,0000,0000,0000,,Уходи.
Dialogue: 0,0:02:35.52,0:02:36.90,Default,,0000,0000,0000,,Подозрительный.
Dialogue: 0,0:02:36.90,0:02:38.77,Default,,0000,0000,0000,,Мы говорили о Конраде.
Dialogue: 0,0:02:38.77,0:02:41.19,Default,,0000,0000,0000,,Что если он же убил и пса фрау Хильман?
Dialogue: 0,0:02:41.48,0:02:44.28,Default,,0000,0000,0000,,Да он выстрелить не способен.
Dialogue: 0,0:02:45.45,0:02:46.53,Default2,,0000,0000,0000,,Точно.
Dialogue: 0,0:02:46.53,0:02:49.20,Default2,,0000,0000,0000,,Он просто трусливый алкоголик!
Dialogue: 0,0:02:59.79,0:03:00.63,Default,,0000,0000,0000,,Вот блин.
Dialogue: 0,0:03:01.30,0:03:02.84,Default,,0000,0000,0000,,Как тут искать?
Dialogue: 0,0:03:02.84,0:03:04.21,Default,,0000,0000,0000,,Эй, Меркель!
Dialogue: 0,0:03:04.22,0:03:06.13,Default,,0000,0000,0000,,Поехали отсюда!
Dialogue: 0,0:03:07.93,0:03:09.18,Default,,0000,0000,0000,,Меркель!
Dialogue: 0,0:03:19.73,0:03:20.52,Default,,0000,0000,0000,,Я... {\alpha&HFF&}я... я нашёл его!
Dialogue: 0,0:03:20.52,0:03:22.64,Default,,0000,0000,0000,,Я... я... {\alpha&HFF&}я нашёл его!
Dialogue: 0,0:03:22.64,0:03:23.44,Default,,0000,0000,0000,,Я... я... я нашёл его!
Dialogue: 0,0:03:23.44,0:03:24.82,Default,,0000,0000,0000,,Я нашёл его!
Dialogue: 0,0:03:25.86,0:03:26.95,Default,,0000,0000,0000,,Меркель!
Dialogue: 0,0:03:27.28,0:03:27.91,Default,,0000,0000,0000,,Мер...
Dialogue: 0,0:03:31.37,0:03:32.53,Default,,0000,0000,0000,,Меркель.
Dialogue: 0,0:03:49.01,0:03:50.30,Default,,0000,0000,0000,,Это Лауфер!
Dialogue: 0,0:03:50.30,0:03:51.80,Default,,0000,0000,0000,,Ответьте!
Dialogue: 0,0:03:52.22,0:03:52.97,Default,,0000,0000,0000,,Кто-нибудь!
Dialogue: 0,0:03:52.97,0:03:54.35,Default,,0000,0000,0000,,Кто-нибудь ответьте!
Dialogue: 0,0:04:04.90,0:04:08.57,Default,,0000,0000,0000,,Я заберу и твой пистолет.
Dialogue: 0,0:04:17.96,0:04:20.92,Default2,,0000,0000,0000,,Да он выстрелить не способен.
Dialogue: 0,0:04:22.42,0:04:23.92,Default2,,0000,0000,0000,,Точно.
Dialogue: 0,0:04:24.38,0:04:27.34,Default2,,0000,0000,0000,,Он просто трусливый алкоголик!
Dialogue: 0,0:04:57.54,0:04:58.83,Default,,0000,0000,0000,,Мёртвые...
Dialogue: 0,0:04:58.83,0:05:00.58,Default,,0000,0000,0000,,По всему городу.
Dialogue: 0,0:05:01.67,0:05:03.54,Default,,0000,0000,0000,,Словно на поле боя.
Dialogue: 0,0:05:13.64,0:05:14.35,Default,,0000,0000,0000,,Вим?
Dialogue: 0,0:05:16.85,0:05:18.14,Default,,0000,0000,0000,,Что случилось, Вим?
Dialogue: 0,0:05:24.86,0:05:25.81,Default,,0000,0000,0000,,Всё хорошо.
Dialogue: 0,0:05:26.19,0:05:27.52,Default,,0000,0000,0000,,Успокойся.
Dialogue: 0,0:05:27.53,0:05:28.40,Default,,0000,0000,0000,,Это я.
Dialogue: 0,0:05:29.36,0:05:30.32,Default,,0000,0000,0000,,Я...
Dialogue: 0,0:05:30.74,0:05:31.90,Default,,0000,0000,0000,,Я...
Dialogue: 0,0:05:31.91,0:05:33.03,Default,,0000,0000,0000,,Успокойся.
Dialogue: 0,0:05:33.03,0:05:35.37,Default,,0000,0000,0000,,Отпусти пистолет.
Dialogue: 0,0:05:36.70,0:05:38.83,Default,,0000,0000,0000,,Я не помню...
Dialogue: 0,0:05:38.83,0:05:40.70,Default,,0000,0000,0000,,Это я стрелял?
Dialogue: 0,0:05:40.71,0:05:43.12,Default,,0000,0000,0000,,Они доставали меня.
Dialogue: 0,0:05:43.12,0:05:44.38,Default,,0000,0000,0000,,Я...
Dialogue: 0,0:05:50.80,0:05:51.41,Default,,0000,0000,0000,,Вим, {\alpha&HFF&}ты...
Dialogue: 0,0:05:51.41,0:05:52.63,Default,,0000,0000,0000,,Вим, ты...
Dialogue: 0,0:05:58.35,0:05:59.56,Default,,0000,0000,0000,,Всё хорошо.
Dialogue: 0,0:06:00.06,0:06:01.31,Default,,0000,0000,0000,,Успокойся.
Dialogue: 0,0:06:01.31,0:06:02.64,Default,,0000,0000,0000,,Теперь всё в порядке.
Dialogue: 0,0:06:02.64,0:06:03.77,Default,,0000,0000,0000,,Не бойся.
Dialogue: 0,0:06:04.77,0:06:06.73,Default,,0000,0000,0000,,Успокойся и вспомни.
Dialogue: 0,0:06:07.69,0:06:10.61,Default,,0000,0000,0000,,Кто дал тебе этот пистолет?
Dialogue: 0,0:06:12.86,0:06:14.07,Default,,0000,0000,0000,,Держитесь!
Dialogue: 0,0:06:14.41,0:06:18.20,Default,,0000,0000,0000,,Как вы только добрались сюда, Лауфер.
Dialogue: 0,0:06:18.49,0:06:20.66,Default,,0000,0000,0000,,С-свяжитесь с участком.
Dialogue: 0,0:06:21.04,0:06:22.66,Default,,0000,0000,0000,,Телефон не работает.
Dialogue: 0,0:06:22.96,0:06:25.54,Default,,0000,0000,0000,,Он забрал мой пистолет.
Dialogue: 0,0:06:25.54,0:06:27.25,Default,,0000,0000,0000,,Кто-то из городских?
Dialogue: 0,0:06:27.59,0:06:29.17,Default,,0000,0000,0000,,Нет.
Dialogue: 0,0:06:29.17,0:06:30.88,Default,,0000,0000,0000,,Я никогда его не видел.
Dialogue: 0,0:06:35.39,0:06:37.55,Default,,0000,0000,0000,,Нужно заняться вашей раной.
Dialogue: 0,0:06:40.72,0:06:42.35,Default,,0000,0000,0000,,Это ваш соучастник?
Dialogue: 0,0:06:43.23,0:06:44.85,Default,,0000,0000,0000,,О чём вы?
Dialogue: 0,0:06:45.35,0:06:48.11,Default,,0000,0000,0000,,Сколько ваших соучастников уже в городе?
Dialogue: 0,0:06:48.61,0:06:50.98,Default,,0000,0000,0000,,На что вы намекаете?
Dialogue: 0,0:06:50.98,0:06:54.32,Default2,,0000,0000,0000,,Вы раздали много пистолетов.
Dialogue: 0,0:06:54.32,0:06:58.12,Default,,0000,0000,0000,,Всучили его даже этому малышу.
Dialogue: 0,0:06:58.87,0:07:00.01,Default,,0000,0000,0000,,Вим!
Dialogue: 0,0:07:00.01,0:07:00.95,Default,,0000,0000,0000,,Пистолет?
Dialogue: 0,0:07:00.95,0:07:02.33,Default,,0000,0000,0000,,Неужели ты...
Dialogue: 0,0:07:02.62,0:07:04.75,Default,,0000,0000,0000,,{\i1}"Ты не мусор".
Dialogue: 0,0:07:04.75,0:07:06.83,Default,,0000,0000,0000,,{\i1}"Не обращай на них внимания".
Dialogue: 0,0:07:06.83,0:07:09.34,Default,,0000,0000,0000,,{\i1}"Ты не зря родился".
Dialogue: 0,0:07:09.84,0:07:13.80,Default,,0000,0000,0000,,Вы так говорили, чтобы подбодрить его.
Dialogue: 0,0:07:16.05,0:07:18.14,Default,,0000,0000,0000,,Он не стал стрелять.
Dialogue: 0,0:07:18.14,0:07:19.93,Default,,0000,0000,0000,,В обойме все пули.
Dialogue: 0,0:07:21.06,0:07:24.14,Default,,0000,0000,0000,,Вим поступил как вы говорили.
Dialogue: 0,0:07:29.65,0:07:31.77,Default,,0000,0000,0000,,Я горжусь тобой, Вим.
Dialogue: 0,0:07:36.15,0:07:37.36,Default,,0000,0000,0000,,Всё хорошо.
Dialogue: 0,0:07:37.74,0:07:39.03,Default,,0000,0000,0000,,Не бойся, Вим.
Dialogue: 0,0:07:42.45,0:07:45.87,Default,,0000,0000,0000,,Город полон трупов.
Dialogue: 0,0:07:50.79,0:07:53.09,Default,,0000,0000,0000,,Сколько вы раздали?
Dialogue: 0,0:07:53.92,0:07:56.55,Default,,0000,0000,0000,,Сколько пистолетов вы привезли в город?
Dialogue: 0,0:07:58.22,0:08:00.89,Default,,0000,0000,0000,,Скольким вы выдали пистолеты?!
Dialogue: 0,0:08:01.51,0:08:03.64,Default,,0000,0000,0000,,Не злите меня!
Dialogue: 0,0:08:04.60,0:08:07.18,Default,,0000,0000,0000,,Вы пожалеете, если разозлите меня!
Dialogue: 0,0:08:07.19,0:08:09.90,Default,,0000,0000,0000,,Он так похож на нашего внука.
Dialogue: 0,0:08:10.61,0:08:11.52,Default,,0000,0000,0000,,Что?
Dialogue: 0,0:08:12.23,0:08:16.69,Default,,0000,0000,0000,,Он так похож на нашего умершего внука.
Dialogue: 0,0:08:17.49,0:08:18.45,Default,,0000,0000,0000,,Он?
Dialogue: 0,0:08:18.95,0:08:22.20,Default,,0000,0000,0000,,Он знал так много о нас.
Dialogue: 0,0:08:22.20,0:08:25.45,Default,,0000,0000,0000,,Он был похож на нашего внука как две капли воды.
Dialogue: 0,0:08:25.79,0:08:27.16,Default,,0000,0000,0000,,Кто это он?
Dialogue: 0,0:08:27.62,0:08:30.92,Default,,0000,0000,0000,,Вы писали письмо умершему внуку.
Dialogue: 0,0:08:30.92,0:08:33.71,Default,,0000,0000,0000,,Так вы сообщали ему о происходящем.
Dialogue: 0,0:08:34.25,0:08:35.67,Default,,0000,0000,0000,,Кто этот он?
Dialogue: 0,0:08:36.67,0:08:38.80,Default,,0000,0000,0000,,Ему нужен я.
Dialogue: 0,0:08:40.01,0:08:42.43,Default,,0000,0000,0000,,Уверен.
Dialogue: 0,0:08:45.22,0:08:46.02,Default,,0000,0000,0000,,Да.
Dialogue: 0,0:08:47.10,0:08:49.48,Default,,0000,0000,0000,,Вы правы, герр Поппе.
Dialogue: 0,0:08:49.77,0:08:53.81,Default,,0000,0000,0000,,Нет. Франц Бонапарта.
Dialogue: 0,0:08:59.70,0:09:02.74,Default2,,0000,0000,0000,,На юге Германии не прекращаются сильные дожди,
Dialogue: 0,0:09:03.33,0:09:06.66,Default2,,0000,0000,0000,,что причиняет Баварии значительный ущерб.
Dialogue: 0,0:09:07.54,0:09:10.17,Default2,,0000,0000,0000,,{\an8}В земле объявлена готовность четвертой степени,
Dialogue: 0,0:09:07.95,0:09:10.50,Default,,0000,0000,0000,,Вы слишком много курите!
Dialogue: 0,0:09:10.21,0:09:11.80,Default2,,0000,0000,0000,,{\an8}так как ущерб всё больше.
Dialogue: 0,0:09:10.79,0:09:13.21,Default,,0000,0000,0000,,Ну и что. Зато я бросила пить.
Dialogue: 0,0:09:13.54,0:09:15.71,Default,,0000,0000,0000,,И курить бы.
Dialogue: 0,0:09:17.21,0:09:18.48,Default,,0000,0000,0000,,Дитер, {\alpha&HFF&}что ты рисуешь?
Dialogue: 0,0:09:18.48,0:09:20.51,Default,,0000,0000,0000,,Дитер, что ты рисуешь?
Dialogue: 0,0:09:22.93,0:09:23.68,Default,,0000,0000,0000,,Что скажете?
Dialogue: 0,0:09:23.68,0:09:24.22,Default,,0000,0000,0000,,Похоже?
Dialogue: 0,0:09:24.93,0:09:25.72,Default,,0000,0000,0000,,Кто это?
Dialogue: 0,0:09:26.01,0:09:27.17,Default,,0000,0000,0000,,Да Тэнма же! {\alpha&HFF&}Тэнма!
Dialogue: 0,0:09:27.17,0:09:27.97,Default,,0000,0000,0000,,Да Тэнма же! Тэнма!
Dialogue: 0,0:09:28.48,0:09:31.31,Default,,0000,0000,0000,,Я отнесу его в полицию.
Dialogue: 0,0:09:32.35,0:09:34.94,Default,,0000,0000,0000,,Они не верят самому важному.
Dialogue: 0,0:09:35.69,0:09:37.52,Default,,0000,0000,0000,,Так что я им разжую.
Dialogue: 0,0:09:40.65,0:09:43.07,Default,,0000,0000,0000,,Я о нём говорю.
Dialogue: 0,0:09:43.37,0:09:47.12,Default,,0000,0000,0000,,Он один отправился охотиться за монстром.
Dialogue: 0,0:09:49.08,0:09:50.50,Default,,0000,0000,0000,,Тэнма {\alpha&HFF&}вернётся?
Dialogue: 0,0:09:50.50,0:09:51.75,Default,,0000,0000,0000,,Тэнма вернётся?
Dialogue: 0,0:09:53.88,0:09:56.75,Default2,,0000,0000,0000,,Далее сообщения о разрушениях.
Dialogue: 0,0:09:57.21,0:09:58.75,Default2,,0000,0000,0000,,Из-за разлива реки Эльгар
Dialogue: 0,0:09:58.76,0:10:00.09,Default2,,0000,0000,0000,,некоторые города отрезаны.
Dialogue: 0,0:10:00.09,0:10:02.80,Default2,,0000,0000,0000,,Железнодорожное сообщение также нарушено.
Dialogue: 0,0:10:02.80,0:10:05.34,Default2,,0000,0000,0000,,Из-за обрывов линий электропередач невозможно связаться
Dialogue: 0,0:10:05.35,0:10:07.22,Default2,,0000,0000,0000,,с некоторыми населёнными пунктами.
Dialogue: 0,0:10:07.56,0:10:10.14,Default,,0000,0000,0000,,Это письмо пришло три дня назад.
Dialogue: 0,0:10:10.14,0:10:12.48,Default,,0000,0000,0000,,Посоветовавшись с доктором Гилленом,
Dialogue: 0,0:10:12.48,0:10:16.27,Default,,0000,0000,0000,,мы решили показать его тебе.
Dialogue: 0,0:10:16.73,0:10:17.90,Default,,0000,0000,0000,,Прошу вас.
Dialogue: 0,0:10:26.03,0:10:26.99,Default,,0000,0000,0000,,{\i1}Нине.
Dialogue: 0,0:10:28.12,0:10:30.79,Default,,0000,0000,0000,,{\i1}"Я жду тебя в Руэнхайме".
Dialogue: 0,0:10:32.46,0:10:33.29,Default,,0000,0000,0000,,Йохан.
Dialogue: 0,0:10:34.17,0:10:36.04,Default,,0000,0000,0000,,Ты тоже так думаешь?
Dialogue: 0,0:10:37.25,0:10:41.30,Default,,0000,0000,0000,,Ты уже говорила о том, что он задумал.
Dialogue: 0,0:10:41.97,0:10:43.80,Default,,0000,0000,0000,,Идеальное самоубийство.
Dialogue: 0,0:10:46.43,0:10:49.43,Default,,0000,0000,0000,,Умрут многие невиновные.
Dialogue: 0,0:10:50.47,0:10:51.89,Default,,0000,0000,0000,,Руэнхайм.
Dialogue: 0,0:10:52.27,0:10:55.23,Default,,0000,0000,0000,,Это маленький городок на юге Германии.
Dialogue: 0,0:10:56.02,0:10:58.81,Default,,0000,0000,0000,,Возможно, Тэнма направился туда.
Dialogue: 0,0:10:59.77,0:11:00.86,Default,,0000,0000,0000,,Я должна ехать.
Dialogue: 0,0:11:01.86,0:11:03.65,Default,,0000,0000,0000,,Отпустите меня.
Dialogue: 0,0:11:07.45,0:11:09.91,Default,,0000,0000,0000,,Какое странное чувство.
Dialogue: 0,0:11:10.29,0:11:15.25,Default,,0000,0000,0000,,Сначала я считал, что вы лишь плод воображения одного человека.
Dialogue: 0,0:11:15.50,0:11:20.79,Default,,0000,0000,0000,,Словно персонаж из ваших книг.
Dialogue: 0,0:11:23.17,0:11:27.76,Default,,0000,0000,0000,,Многие годы я вёл расследования, собирая объективную информацию.
Dialogue: 0,0:11:28.18,0:11:31.10,Default,,0000,0000,0000,,В этот же раз, я отбросил информацию
Dialogue: 0,0:11:31.10,0:11:33.77,Default,,0000,0000,0000,,и следовал за воображением этого человека.
Dialogue: 0,0:11:34.43,0:11:37.69,Default,,0000,0000,0000,,Следуя за подсказками, отчасти ради собственного веселья,
Dialogue: 0,0:11:37.69,0:11:42.44,Default,,0000,0000,0000,,я встретил молодого человека, часто бывавшего в Доме Красных Роз.
Dialogue: 0,0:11:43.65,0:11:45.32,Default,,0000,0000,0000,,Это был ваш сын.
Dialogue: 0,0:11:47.20,0:11:49.53,Default,,0000,0000,0000,,Эту открытку нарисовали вы.
Dialogue: 0,0:11:49.91,0:11:51.87,Default,,0000,0000,0000,,И подписались настоящим именем
Dialogue: 0,0:11:51.87,0:11:53.54,Default,,0000,0000,0000,,Клаус Поппе, К.П.
Dialogue: 0,0:11:54.08,0:11:58.17,Default,,0000,0000,0000,,Даже увидев этот пейзаж, который вы рисовали,
Dialogue: 0,0:11:58.50,0:12:00.58,Default,,0000,0000,0000,,мне продолжает казаться,
Dialogue: 0,0:12:00.84,0:12:04.51,Default,,0000,0000,0000,,что герой вашей сказки сошёл с её страниц.
Dialogue: 0,0:12:04.51,0:12:06.55,Default,,0000,0000,0000,,Но это реальность.
Dialogue: 0,0:12:06.88,0:12:11.85,Default,,0000,0000,0000,,В списке бежавших из Чехословакии
Dialogue: 0,0:12:11.85,0:12:14.31,Default,,0000,0000,0000,,было имя Клауса Поппе.
Dialogue: 0,0:12:14.72,0:12:18.56,Default,,0000,0000,0000,,Незадолго до падения Берлинской стены вы укрылись здесь.
Dialogue: 0,0:12:20.81,0:12:23.07,Default,,0000,0000,0000,,От чего вы убегали?
Dialogue: 0,0:12:24.90,0:12:27.07,Default,,0000,0000,0000,,От таких как я?
Dialogue: 0,0:12:28.95,0:12:34.45,Default,,0000,0000,0000,,511-ый детдом в ГДР был создан на основе ваших работ.
Dialogue: 0,0:12:34.87,0:12:37.58,Default,,0000,0000,0000,,Там меня "создали" таким.
Dialogue: 0,0:12:38.96,0:12:42.08,Default,,0000,0000,0000,,Вы убегали от подобных мне?
Dialogue: 0,0:12:44.38,0:12:46.21,Default,,0000,0000,0000,,Я знаю.
Dialogue: 0,0:12:46.21,0:12:51.01,Default,,0000,0000,0000,,Чего он, мальчик по имени Йохан, хочет добиться.
Dialogue: 0,0:12:51.51,0:12:53.10,Default,,0000,0000,0000,,И сейчас,
Dialogue: 0,0:12:53.47,0:12:56.85,Default,,0000,0000,0000,,в этом городе, это воплощается в реальность.
Dialogue: 0,0:13:00.02,0:13:01.10,Default,,0000,0000,0000,,Снова выстрел.
Dialogue: 0,0:13:01.94,0:13:05.48,Default,,0000,0000,0000,,Пока мы шли сюда, я видела столько убитых.
Dialogue: 0,0:13:06.44,0:13:08.94,Default,,0000,0000,0000,,Что творится в этом городе?
Dialogue: 0,0:13:10.95,0:13:13.45,Default,,0000,0000,0000,,Давай поскорее уедем отсюда!
Dialogue: 0,0:13:13.45,0:13:15.24,Default,,0000,0000,0000,,Не сейчас.
Dialogue: 0,0:13:15.24,0:13:17.45,Default,,0000,0000,0000,,Дороги закрыты.
Dialogue: 0,0:13:18.08,0:13:21.50,Default,,0000,0000,0000,,Боже. Что ты делаешь?
Dialogue: 0,0:13:21.50,0:13:23.04,Default,,0000,0000,0000,,Уходишь и приходишь.
Dialogue: 0,0:13:23.04,0:13:24.46,Default,,0000,0000,0000,,И каждый раз лезешь в душ.
Dialogue: 0,0:13:25.75,0:13:29.88,Default,,0000,0000,0000,,Ненавижу запах пороха и крови.
Dialogue: 0,0:13:33.35,0:13:35.26,Default,,0000,0000,0000,,Успокойся.
Dialogue: 0,0:13:35.26,0:13:38.60,Default,,0000,0000,0000,,Я заказал горячего чаю.
Dialogue: 0,0:13:43.10,0:13:45.02,Default,,0000,0000,0000,,Всё хорошо.
Dialogue: 0,0:13:45.02,0:13:46.90,Default,,0000,0000,0000,,Не бойся.
Dialogue: 0,0:13:47.44,0:13:51.15,Default,,0000,0000,0000,,После дождя ничего не останется.
Dialogue: 0,0:13:52.61,0:13:54.47,Default,,0000,0000,0000,,Не останется? {\alpha&HFF&}Чего именно?
Dialogue: 0,0:13:54.47,0:13:55.16,Default,,0000,0000,0000,,Не останется? Чего именно?
Dialogue: 0,0:13:56.91,0:13:59.50,Default,,0000,0000,0000,,Воспоминаний.
Dialogue: 0,0:14:01.96,0:14:05.38,Default,,0000,0000,0000,,Мы отпустим тебя,\N но с некоторыми условиями.
Dialogue: 0,0:14:05.38,0:14:08.00,Default,,0000,0000,0000,,Доктор Гиллен поедет с тобой.
Dialogue: 0,0:14:08.00,0:14:12.01,Default,,0000,0000,0000,,И я не могу дать тебе оружие.
Dialogue: 0,0:14:12.43,0:14:14.76,Default,,0000,0000,0000,,Оно мне не нужно.
Dialogue: 0,0:14:17.39,0:14:19.18,Default,,0000,0000,0000,,Пойду собираться.
Dialogue: 0,0:14:19.18,0:14:23.39,Default,,0000,0000,0000,,Поспешите сделать то, о чём мы говорили.
Dialogue: 0,0:14:24.02,0:14:27.15,Default,,0000,0000,0000,,Дитер и Ева, и вы, доктор Райхвайн.
Dialogue: 0,0:14:27.44,0:14:29.90,Default,,0000,0000,0000,,Вместе с герром Шубартом, Карлом и Лотте.
Dialogue: 0,0:14:29.90,0:14:33.03,Default,,0000,0000,0000,,Всем, кого знает Йохан, нужно скрыться.
Dialogue: 0,0:14:35.16,0:14:38.45,Default,,0000,0000,0000,,Йохан хочет избавиться от всех, кто его помнит.
Dialogue: 0,0:14:46.00,0:14:48.63,Default,,0000,0000,0000,,Быстрей, пока Дитер не заметил!
Dialogue: 0,0:14:54.43,0:14:56.26,Default,,0000,0000,0000,,Дитера.
Dialogue: 0,0:14:56.26,0:14:58.72,Default,,0000,0000,0000,,Вас, доктор Райхвайн.
Dialogue: 0,0:14:58.72,0:15:00.85,Default,,0000,0000,0000,,Карла и Лотте.
Dialogue: 0,0:15:01.18,0:15:03.10,Default,,0000,0000,0000,,Фортнеров.
Dialogue: 0,0:15:03.52,0:15:05.14,Default,,0000,0000,0000,,Тэнму.
Dialogue: 0,0:15:07.73,0:15:10.36,Default,,0000,0000,0000,,Я не хочу забыть никого из вас.
Dialogue: 0,0:15:11.69,0:15:14.28,Default,,0000,0000,0000,,Что бы мне ни хотелось забыть...
Dialogue: 0,0:15:15.24,0:15:16.74,Default,,0000,0000,0000,,А Йохана?
Dialogue: 0,0:15:16.74,0:15:18.53,Default,,0000,0000,0000,,Как же он?
Dialogue: 0,0:15:20.37,0:15:21.70,Default,,0000,0000,0000,,Всегда буду помнить.
Dialogue: 0,0:15:38.01,0:15:39.14,Default,,0000,0000,0000,,Полицейский?
Dialogue: 0,0:15:40.97,0:15:42.39,Default,,0000,0000,0000,,Оружие забрали.
Dialogue: 0,0:15:47.40,0:15:48.69,Default,,0000,0000,0000,,Стоять!
Dialogue: 0,0:15:58.87,0:16:00.12,Default,,0000,0000,0000,,Прошу...
Dialogue: 0,0:16:00.78,0:16:02.03,Default,,0000,0000,0000,,Спасите...
Dialogue: 0,0:16:03.41,0:16:04.58,Default,,0000,0000,0000,,Кто в вас стрелял?
Dialogue: 0,0:16:05.16,0:16:07.58,Default,,0000,0000,0000,,По всему городу стрельба...
Dialogue: 0,0:16:07.96,0:16:10.46,Default,,0000,0000,0000,,Сначала пришли...
Dialogue: 0,0:16:10.46,0:16:13.75,Default,,0000,0000,0000,,вооружённые люди...
Dialogue: 0,0:16:14.51,0:16:15.96,Default,,0000,0000,0000,,А после горожане...
Dialogue: 0,0:16:15.97,0:16:17.68,Default,,0000,0000,0000,,достали оружие...
Dialogue: 0,0:16:17.68,0:16:19.22,Default,,0000,0000,0000,,и стали...
Dialogue: 0,0:16:19.22,0:16:20.59,Default,,0000,0000,0000,,стрелять друг в друга...
Dialogue: 0,0:16:22.22,0:16:23.89,Default,,0000,0000,0000,,Я должен...
Dialogue: 0,0:16:23.89,0:16:25.06,Default,,0000,0000,0000,,позвать на помощь.
Dialogue: 0,0:16:25.68,0:16:27.69,Default,,0000,0000,0000,,Я должен...
Dialogue: 0,0:16:28.23,0:16:29.60,Default,,0000,0000,0000,,спасти детей...
Dialogue: 0,0:16:32.69,0:16:34.07,Default,,0000,0000,0000,,Должен...
Dialogue: 0,0:16:42.08,0:16:43.28,Default,,0000,0000,0000,,Йохан.
Dialogue: 0,0:16:43.58,0:16:46.16,Default,,0000,0000,0000,,Это имя я впервые услышал
Dialogue: 0,0:16:46.83,0:16:49.21,Default,,0000,0000,0000,,в 95-ом году.
Dialogue: 0,0:16:49.25,0:16:51.67,Default,,0000,0000,0000,,Из показаний одного нейрохирурга.
Dialogue: 0,0:16:52.00,0:16:53.63,Default,,0000,0000,0000,,Доктора Тэнмы.
Dialogue: 0,0:16:54.46,0:16:58.47,Default,,0000,0000,0000,,Вы признаете, что ваши выводы были ошибочны?
Dialogue: 0,0:16:59.55,0:17:00.51,Default,,0000,0000,0000,,Нет.
Dialogue: 0,0:17:00.51,0:17:04.18,Default,,0000,0000,0000,,Для меня он остаётся ключевой фигурой.
Dialogue: 0,0:17:04.64,0:17:07.93,Default,,0000,0000,0000,,Йохан же лишь выдуманный персонаж.
Dialogue: 0,0:17:09.94,0:17:11.60,Default,,0000,0000,0000,,Выдуманный персонаж...
Dialogue: 0,0:17:12.06,0:17:15.57,Default,,0000,0000,0000,,Эти слова не давали мне покоя весь мой отпуск.
Dialogue: 0,0:17:16.11,0:17:20.45,Default,,0000,0000,0000,,Как живой человек может стать выдуманным?
Dialogue: 0,0:17:21.32,0:17:23.24,Default,,0000,0000,0000,,Ответ прост.
Dialogue: 0,0:17:23.24,0:17:25.03,Default,,0000,0000,0000,,Все, знающие его...
Dialogue: 0,0:17:25.04,0:17:27.58,Default,,0000,0000,0000,,Все, знающие его прошлое...
Dialogue: 0,0:17:27.64,0:17:29.90,Default,,0000,0000,0000,,Всех их нужно стереть.
Dialogue: 0,0:17:29.91,0:17:32.29,Default,,0000,0000,0000,,Всё заканчивается, герр Бонапарта,
Dialogue: 0,0:17:32.29,0:17:34.71,Default,,0000,0000,0000,,так же, как в одной вашей книге с картинками.
Dialogue: 0,0:17:37.42,0:17:39.76,Default,,0000,0000,0000,,"И хотя теперь у него было имя,
Dialogue: 0,0:17:39.76,0:17:42.93,Default,,0000,0000,0000,,не осталось никого, кто мог бы назвать его по имени.
Dialogue: 0,0:17:43.76,0:17:47.22,Default,,0000,0000,0000,,Йохан. Чудесное имя".
Dialogue: 0,0:17:50.06,0:17:53.69,Default,,0000,0000,0000,,Если это происходит в этом городе...
Dialogue: 0,0:17:54.48,0:17:56.90,Default,,0000,0000,0000,,На месте Йохана я бы поступил так же.
Dialogue: 0,0:17:56.90,0:17:59.28,Default,,0000,0000,0000,,Я тоже выдуманный персонаж.
Dialogue: 0,0:17:59.61,0:18:03.36,Default,,0000,0000,0000,,Я не человек по имени Ноймайер, записавшийся в гостевой книге.
Dialogue: 0,0:18:03.70,0:18:06.28,Default,,0000,0000,0000,,И не Вольфганг Гриммер.
Dialogue: 0,0:18:06.95,0:18:09.29,Default,,0000,0000,0000,,Я никто.
Dialogue: 0,0:18:11.54,0:18:13.87,Default,,0000,0000,0000,,Пускай мы исчезнем вместе.
Dialogue: 0,0:18:13.88,0:18:17.80,Default,,0000,0000,0000,,Вместе с тем, кто лишил нас памяти и имени.
Dialogue: 0,0:18:19.84,0:18:21.30,Default,,0000,0000,0000,,Я ждал.
Dialogue: 0,0:18:21.84,0:18:26.64,Default,,0000,0000,0000,,Я ждал здесь своего приговора.
Dialogue: 0,0:18:29.47,0:18:31.77,Default,,0000,0000,0000,,Я не боюсь умереть.
Dialogue: 0,0:18:32.06,0:18:35.65,Default,,0000,0000,0000,,Я лишь не знаю, как искупить свой грех.
Dialogue: 0,0:18:36.40,0:18:40.03,Default,,0000,0000,0000,,Я был готов принять своё наказание.
Dialogue: 0,0:18:40.57,0:18:42.78,Default,,0000,0000,0000,,Ждали?
Dialogue: 0,0:18:42.78,0:18:45.28,Default,,0000,0000,0000,,Не боитесь умереть?
Dialogue: 0,0:18:47.28,0:18:50.29,Default,,0000,0000,0000,,Вы понимаете, какой грех совершили?
Dialogue: 0,0:18:50.87,0:18:55.29,Default,,0000,0000,0000,,Вы понимаете, что значит - стереть грань между добром и злом?
Dialogue: 0,0:18:55.75,0:19:00.05,Default,,0000,0000,0000,,Вы представляете, что будет, если разбудить монстра в человеке?
Dialogue: 0,0:19:02.80,0:19:04.01,Default,,0000,0000,0000,,Люди...
Dialogue: 0,0:19:04.26,0:19:06.84,Default,,0000,0000,0000,,Люди должны считать еду вкусной.
Dialogue: 0,0:19:07.35,0:19:10.47,Default,,0000,0000,0000,,Они должны дорожить пикниками в выходные.
Dialogue: 0,0:19:10.47,0:19:13.98,Default,,0000,0000,0000,,Они должны считать пиво после работы особенно вкусным.
Dialogue: 0,0:19:14.44,0:19:15.52,Default,,0000,0000,0000,,Люди...
Dialogue: 0,0:19:15.85,0:19:17.19,Default,,0000,0000,0000,,Люди...
Dialogue: 0,0:19:18.06,0:19:23.61,Default,,0000,0000,0000,,Должны горевать, когда их ребёнок умирает.
Dialogue: 0,0:19:25.07,0:19:27.16,Default,,0000,0000,0000,,Я не дам вам умереть.
Dialogue: 0,0:19:27.82,0:19:30.08,Default,,0000,0000,0000,,Я увезу вас отсюда
Dialogue: 0,0:19:30.08,0:19:31.66,Default,,0000,0000,0000,,и всё опубликую.
Dialogue: 0,0:19:32.58,0:19:36.04,Default,,0000,0000,0000,,Мир узнает о монстре,
Dialogue: 0,0:19:36.04,0:19:38.50,Default,,0000,0000,0000,,разбуженном вами.
Dialogue: 0,0:19:38.50,0:19:39.96,Default,,0000,0000,0000,,До тех пор
Dialogue: 0,0:19:39.96,0:19:41.75,Default,,0000,0000,0000,,я буду защищать вас.
Dialogue: 0,0:19:48.80,0:19:50.51,Default,,0000,0000,0000,,Где Йохан?
Dialogue: 0,0:19:50.85,0:19:52.64,Default,,0000,0000,0000,,Н-не знаю.
Dialogue: 0,0:19:53.73,0:19:57.31,Default,,0000,0000,0000,,Кто-то должен управлять всей этой бойней.
Dialogue: 0,0:19:57.65,0:19:59.23,Default,,0000,0000,0000,,Где он?
Dialogue: 0,0:19:59.61,0:20:01.48,Default,,0000,0000,0000,,Не... не знаю.
Dialogue: 0,0:20:04.03,0:20:05.15,Default,,0000,0000,0000,,Где?
Dialogue: 0,0:20:07.61,0:20:08.99,Default,,0000,0000,0000,,Новый выстрел.
Dialogue: 0,0:20:21.84,0:20:23.00,Default,,0000,0000,0000,,Здесь есть кто-нибудь?
Dialogue: 0,0:20:24.92,0:20:26.05,Default,,0000,0000,0000,,Видите?
Dialogue: 0,0:20:26.05,0:20:28.05,Default,,0000,0000,0000,,У меня ничего нет.
Dialogue: 0,0:20:36.48,0:20:37.52,Default,,0000,0000,0000,,Всё хорошо.
Dialogue: 0,0:20:37.94,0:20:39.02,Default,,0000,0000,0000,,Не бойтесь.
Dialogue: 0,0:20:43.36,0:20:45.53,Default,,0000,0000,0000,,Я пришёл помочь вам.
Dialogue: 0,0:20:45.53,0:20:46.53,Default,,0000,0000,0000,,Не бойтесь.
Dialogue: 0,0:20:48.86,0:20:50.11,Default,,0000,0000,0000,,Здесь опасно оставаться.
Dialogue: 0,0:20:50.41,0:20:51.62,Default,,0000,0000,0000,,Понимаете?
Dialogue: 0,0:20:51.62,0:20:52.83,Default,,0000,0000,0000,,Вам нужно уйти из города.
Dialogue: 0,0:20:56.20,0:20:57.20,Default,,0000,0000,0000,,Не плачьте!
Dialogue: 0,0:20:57.58,0:21:00.08,Default,,0000,0000,0000,,Я отведу вас к лесу.
Dialogue: 0,0:21:00.08,0:21:01.04,Default,,0000,0000,0000,,Вы можете бежать?
Dialogue: 0,0:21:03.38,0:21:08.17,Default,,0000,0000,0000,,Он в отеле "Бергбах"!
Dialogue: 0,0:21:09.09,0:21:10.18,Default,,0000,0000,0000,,Понятно.
Dialogue: 0,0:21:11.93,0:21:14.47,Default,,0000,0000,0000,,Это единственный пистолет.
Dialogue: 0,0:21:15.93,0:21:17.89,Default,,0000,0000,0000,,Они были снаружи.
Dialogue: 0,0:21:18.52,0:21:19.89,Default,,0000,0000,0000,,Нам очень жаль.
Dialogue: 0,0:21:19.89,0:21:23.27,Default,,0000,0000,0000,,Это случилось из-за моего выигрыша.
Dialogue: 0,0:21:25.32,0:21:29.90,Default,,0000,0000,0000,,Если бы мы сразу сообщили о смерти Конрада...
Dialogue: 0,0:21:29.90,0:21:32.78,Default,,0000,0000,0000,,До того, как город сошёл с ума...
Dialogue: 0,0:21:35.91,0:21:37.87,Default,,0000,0000,0000,,Вы купили их?
Dialogue: 0,0:21:37.87,0:21:40.37,Default,,0000,0000,0000,,Я-я не выстрелил из них ни разу!
Dialogue: 0,0:21:40.37,0:21:41.58,Default,,0000,0000,0000,,Клянусь вам!
Dialogue: 0,0:21:44.92,0:21:47.17,Default,,0000,0000,0000,,Возьму это и это.
Dialogue: 0,0:21:47.88,0:21:50.01,Default,,0000,0000,0000,,Защищайте отель.
Dialogue: 0,0:21:50.01,0:21:51.09,Default,,0000,0000,0000,,А вы?
Dialogue: 0,0:21:51.55,0:21:54.35,Default,,0000,0000,0000,,Здесь даже у горожан оружие.
Dialogue: 0,0:21:54.35,0:21:55.55,Default,,0000,0000,0000,,Я полицейский.
Dialogue: 0,0:21:55.56,0:21:57.22,Default,,0000,0000,0000,,Мне ли не знать разницу.
Dialogue: 0,0:21:58.93,0:22:00.43,Default,,0000,0000,0000,,Кстати, герр Гриммер.
Dialogue: 0,0:22:02.27,0:22:03.77,Default,,0000,0000,0000,,Когда закончим,
Dialogue: 0,0:22:03.77,0:22:05.56,Default,,0000,0000,0000,,угощу вас пивом.
Dialogue: 0,0:22:05.86,0:22:07.52,Default,,0000,0000,0000,,С радостью.
Dialogue: 0,0:22:07.53,0:22:08.69,Default,,0000,0000,0000,,Вкусным пивом.
Dialogue: 0,0:22:12.74,0:22:13.66,Default,,0000,0000,0000,,Давайте!
Dialogue: 0,0:22:16.03,0:22:16.74,Default,,0000,0000,0000,,Бегите!
Dialogue: 0,0:22:17.37,0:22:18.74,Default,,0000,0000,0000,,Вы должны жить!
Dialogue: 0,0:23:45.25,0:23:49.71,Name,,0000,0000,0000,,{\fad(870,0)\pos(323,213)}Глава 71
Dialogue: 0,0:23:45.25,0:23:49.71,Name,,0000,0000,0000,,{\fad(870,0)\pos(323,389)\fscx120\bord5}Гнев Невероятного Штайнера
Dialogue: 0,0:22:25.60,0:22:27.15,ending,,0000,0000,0000,,{\fad(210,210)}Да
Dialogue: 0,0:22:28.65,0:22:31.86,ending,,0000,0000,0000,,{\fad(210,210)}Теперь ты этот мир
Dialogue: 0,0:22:32.85,0:22:41.19,ending,,0000,0000,0000,,{\fad(210,210)}познаёшь пристальным взглядом
Dialogue: 0,0:22:42.14,0:22:43.26,ending,,0000,0000,0000,,{\fad(210,210)}Да
Dialogue: 0,0:22:45.00,0:22:48.20,ending,,0000,0000,0000,,{\fad(210,210)}Твои глаза
Dialogue: 0,0:22:49.33,0:22:57.79,ending,,0000,0000,0000,,{\fad(210,210)}верят в нежность
Dialogue: 0,0:23:15.32,0:23:23.46,ending,,0000,0000,0000,,{\fad(210,210)}Сделай этот мир домом для своей земли гармонии
Dialogue: 0,0:23:23.46,0:23:31.86,ending,,0000,0000,0000,,{\fad(210,210)}Сделай его домом для своей земли чистоты
Dialogue: 0,0:23:31.86,0:23:33.96,ending,,0000,0000,0000,,{\fad(210,210)}Сделай его домом
